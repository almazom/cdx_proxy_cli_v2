#!/usr/bin/env bash
set -euo pipefail

die() {
  echo "$1" >&2
  exit "${2:-1}"
}

print_shell_command() {
  print_shell_command_with_prefix 'command' "$@"
}

print_shell_command_with_prefix() {
  local prefix="$1"
  shift
  local arg
  local first=1

  printf '%s=' "$prefix"
  for arg in "$@"; do
    if (( first )); then
      first=0
    else
      printf ' '
    fi
    printf '%q' "$arg"
  done
  printf '\n'
}

build_shell_command_string() {
  local arg
  local first=1
  local rendered=""
  local quoted_arg

  for arg in "$@"; do
    if (( first )); then
      first=0
    else
      rendered+=" "
    fi
    printf -v quoted_arg '%q' "$arg"
    rendered+="$quoted_arg"
  done
  printf '%s\n' "$rendered"
}

git_is_inside_work_tree() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

git_worktree_has_changes() {
  local status_output=""
  status_output="$(git status --short --untracked-files=all 2>/dev/null)" || return 1
  [[ -n "$status_output" ]]
}

positive_int_env_or_default() {
  local name="$1"
  local default_value="$2"
  local raw="${!name-}"

  raw="${raw#"${raw%%[![:space:]]*}"}"
  raw="${raw%"${raw##*[![:space:]]}"}"
  if [[ -z "$raw" ]]; then
    printf '%s\n' "$default_value"
    return 0
  fi

  if [[ "$raw" =~ ^[0-9]+$ ]] && (( raw > 0 )); then
    printf '%s\n' "$raw"
    return 0
  fi

  printf '%s\n' "$default_value"
}

fixed_shortcut_error() {
  local shortcut_flag="$1"
  die "codex_wp: ${shortcut_flag} does not accept additional arguments. Use only 'codex_wp ${shortcut_flag}'." 2
}

fixed_shortcut_prompt() {
  local shortcut_name="$1"

  case "$shortcut_name" in
    auto_commit)
      cat <<'EOF'
Use $auto-commit.
Run the full auto-commit skill workflow for the current repository.
Commit everything currently relevant in git status using atomic commits.
Run the fitting checks before committing.
Scan diffs for secrets.
Push if a remote already exists.
Report briefly in simplified Russian.
EOF
      ;;
    code_simplifier)
      cat <<'EOF'
Use $code-simplifier.
Run a narrow simplification pass for the current repository.
Focus first on currently modified or recently touched code.
If the repository is clean, still run a narrow relevant simplification pass instead of a wide repo rewrite.
Preserve behavior exactly.
Keep edits tight and readable.
Run relevant tests after changes.
Report only significant simplifications.
EOF
      ;;
    simplify_then_commit)
      die "codex_wp: shortcut prompts for 'simplify_then_commit' must be built step-by-step."
      ;;
    *)
      die "codex_wp: unsupported fixed shortcut '$shortcut_name'."
      ;;
  esac
}

fixed_shortcut_title() {
  local shortcut_name="$1"

  case "$shortcut_name" in
    auto_commit)
      printf '%s\n' "Auto Commit"
      ;;
    code_simplifier)
      printf '%s\n' "Code Simplifier"
      ;;
    simplify_then_commit)
      printf '%s\n' "Simplify + Commit"
      ;;
    *)
      die "codex_wp: unsupported fixed shortcut '$shortcut_name'."
      ;;
  esac
}

build_close_on_success_inner_command() {
  local output_var="$1"
  local shortcut_flag="$2"
  shift 2
  local -n output_ref="$output_var"
  local base_command_string=""
  local failure_message=""
  local shell_script=""

  base_command_string="$(build_shell_command_string "$@")"
  failure_message="codex_wp: ${shortcut_flag} failed; leaving floating pane open."
  shell_script=$(cat <<EOF
$base_command_string
status=\$?
if [[ \$status -eq 0 ]]; then
  if [[ -n "\${ZELLIJ_PANE_ID:-}" ]]; then
    zellij action close-pane --pane-id "\$ZELLIJ_PANE_ID" >/dev/null 2>&1 || true
  fi
  exit 0
fi
printf '%s\n' '$failure_message' >&2
exit "\$status"
EOF
)
  output_ref=(bash -lc "$shell_script")
}

build_simplify_then_commit_inner_command() {
  local output_var="$1"
  local -n output_ref="$output_var"
  local simplify_command_string=""
  local auto_commit_command_string=""
  local shell_script=""

  simplify_command_string="$(
    build_shell_command_string \
      "$script_path" \
      exec \
      "$(fixed_shortcut_prompt "code_simplifier")"
  )"
  auto_commit_command_string="$(
    build_shell_command_string \
      "$script_path" \
      exec \
      "$(fixed_shortcut_prompt "auto_commit")"
  )"
  shell_script=$(cat <<'EOF'
__SIMPLIFY_COMMAND__
status=$?
if [[ $status -ne 0 ]]; then
  printf '%s\n' 'codex_wp: -SA simplification failed; leaving floating pane open.' >&2
  exit "$status"
fi
if [[ -z "$(git status --short --untracked-files=all 2>/dev/null)" ]]; then
  printf '%s\n' 'codex_wp: nothing to commit after simplification.'
  if [[ -n "${ZELLIJ_PANE_ID:-}" ]]; then
    zellij action close-pane --pane-id "$ZELLIJ_PANE_ID" >/dev/null 2>&1 || true
  fi
  exit 0
fi
__AUTO_COMMIT_COMMAND__
status=$?
if [[ $status -eq 0 ]]; then
  if [[ -n "${ZELLIJ_PANE_ID:-}" ]]; then
    zellij action close-pane --pane-id "$ZELLIJ_PANE_ID" >/dev/null 2>&1 || true
  fi
  exit 0
fi
printf '%s\n' 'codex_wp: -SA auto-commit failed; leaving floating pane open.' >&2
exit "$status"
EOF
)
  shell_script="${shell_script/__SIMPLIFY_COMMAND__/$simplify_command_string}"
  shell_script="${shell_script/__AUTO_COMMIT_COMMAND__/$auto_commit_command_string}"
  output_ref=(bash -lc "$shell_script")
}

# Build file references string from array of file paths
# Outputs: "@/abs/path1 @/abs/path2 "
build_file_refs() {
  local files=("$@")
  local file_refs=""
  local abs_path=""
  for f in "${files[@]}"; do
    # Convert to absolute path if relative
    if [[ "$f" = /* ]]; then
      abs_path="$f"
    else
      abs_path="$PWD/$f"
    fi
    file_refs="${file_refs}@${abs_path} "
  done
  printf '%s' "$file_refs"
}

is_help_request() {
  local argv=("$@")
  local arg

  for arg in "${argv[@]}"; do
    case "$arg" in
      -h|--help)
        return 0
        ;;
    esac
  done

  [[ ${#argv[@]} -gt 0 && "${argv[0]}" == "help" ]]
}

find_exec_prompt_index() {
  local argv=("$@")
  local index=0
  local arg

  while (( index < ${#argv[@]} )); do
    arg="${argv[$index]}"
    case "$arg" in
      --)
        ((index++))
        break
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-s|--sandbox|-p|--profile|-C|--cd|--add-dir|--output-schema|--color|-o|--output-last-message|--ask-for-approval)
        ((index+=2))
        continue
        ;;
      --sandbox=*|--ask-for-approval=*)
        ((index++))
        continue
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--skip-git-repo-check|--ephemeral|--json|-h|--help|-V|--version)
        ((index++))
        continue
        ;;
      -*)
        printf '%s\n' "-1"
        return 0
        ;;
      resume|review|help)
        printf '%s\n' "-1"
        return 0
        ;;
      *)
        printf '%s\n' "$index"
        return 0
        ;;
    esac
  done

  while (( index < ${#argv[@]} )); do
    arg="${argv[$index]}"
    case "$arg" in
      resume|review|help)
        printf '%s\n' "-1"
        return 0
        ;;
      *)
        printf '%s\n' "$index"
        return 0
        ;;
    esac
  done

  printf '%s\n' "-1"
}

find_first_passthrough_token() {
  local argv=("$@")
  local index=0
  local arg

  while (( index < ${#argv[@]} )); do
    arg="${argv[$index]}"
    case "$arg" in
      --)
        ((index++))
        break
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-s|--sandbox|-p|--profile|-C|--cd|--add-dir|--output-schema|--color|-o|--output-last-message|--ask-for-approval)
        ((index+=2))
        continue
        ;;
      --sandbox=*|--ask-for-approval=*)
        ((index++))
        continue
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--skip-git-repo-check|--ephemeral|--json|-h|--help|-V|--version)
        ((index++))
        continue
        ;;
      -*)
        ((index++))
        continue
        ;;
      *)
        printf '%s\n' "$arg"
        return 0
        ;;
    esac
  done

  while (( index < ${#argv[@]} )); do
    arg="${argv[$index]}"
    case "$arg" in
      -*)
        ((index++))
        ;;
      *)
        printf '%s\n' "$arg"
        return 0
        ;;
    esac
  done

  printf '\n'
}

find_exec_subcommand_index() {
  local argv=("$@")
  local index=0
  local arg

  while (( index < ${#argv[@]} )); do
    arg="${argv[$index]}"
    case "$arg" in
      --)
        break
        ;;
      -c|--config|--enable|--disable|-i|--image|-m|--model|--local-provider|-s|--sandbox|-p|--profile|-C|--cd|--add-dir|--output-schema|--color|-o|--output-last-message|--ask-for-approval)
        ((index+=2))
        continue
        ;;
      --sandbox=*|--ask-for-approval=*)
        ((index++))
        continue
        ;;
      --oss|--full-auto|--dangerously-bypass-approvals-and-sandbox|--skip-git-repo-check|--ephemeral|--json|-h|--help|-V|--version)
        ((index++))
        continue
        ;;
      exec|e)
        printf '%s\n' "$index"
        return 0
        ;;
      *)
        printf '%s\n' "-1"
        return 0
        ;;
    esac
  done

  printf '%s\n' "-1"
}

has_explicit_execution_policy() {
  local argv=("$@")
  local arg

  for arg in "${argv[@]}"; do
    case "$arg" in
      --dangerously-bypass-approvals-and-sandbox|--full-auto|--sandbox|--sandbox=*|--ask-for-approval|--ask-for-approval=*)
        return 0
        ;;
    esac
  done

  return 1
}

normalize_hook_supervision() {
  local raw="$1"
  local lowered=""

  lowered="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')"

  case "$lowered" in
    observation|observed|under-observation|under_observation|"under observation"|"codex_wp under observation")
      printf '%s\n' "observation"
      ;;
    management|managed|under-management|under_management|"under management"|manage|manager|manage-codex-wp|manage_codex_wp|"manage codex_wp"|"codex_wp under management")
      printf '%s\n' "management"
      ;;
    *)
      return 1
      ;;
  esac
}

hook_effective_supervision() {
  if [[ -n "$hook_supervision" ]]; then
    printf '%s\n' "$hook_supervision"
  else
    printf '%s\n' "manager"
  fi
}

script_path="$(readlink -f "$0")"
script_dir="$(cd "$(dirname "$script_path")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"
codex_wp_python_bin=""

zellij_mode=0
zellij_new_tab_requested=0
zellij_pair_mode=0
zellij_pair_options_seen=0
zellij_tab_name=""
zellij_template="three-vertical"
zellij_cwd=""
zellij_dry_run=0
zellij_floating=0
zellij_pair_layout=""
zellij_pair_json=0
zellij_top=""
zellij_right=""
zellij_float_width=""
zellij_float_height=""
zellij_close_on_exit=""
zellij_pinned=""
zellij_float_name=""
zellij_float_title_prefix=""
zellij_auto_name=""
zellij_title_max_words=""
zellij_title_case=""
zellij_title_fallback=""
zellij_pair_top=""
zellij_pair_right=""
zellij_pair_width=""
zellij_pair_height=""
zellij_pair_gap=""
pair_a_prompt=""
pair_a_file=""
pair_b_prompt=""
pair_b_file=""
fixed_shortcut=""
fixed_shortcut_close_on_success=0
files_to_include=()
prompt_shortcut=""
# --hook* flags
hook_mode=""
hook_prompt=""
hook_times=""
hook_prompt_mode="static"
hook_prompt_mode_explicit=0
hook_auto_stop_on_complete=0
hook_target=""
hook_delivery="mattermost"
hook_delivery_explicit=0
hook_last_message_format="raw"
hook_last_message_format_explicit=0
hook_supervision=""
hook_supervision_explicit=0
hook_extract_intent=0
hook_cleanup_after_run=0
hook_cleanup_project_root=""
args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --)
      args+=("$@")
      break
      ;;
    --zellij-new-tab)
      zellij_new_tab_requested=1
      zellij_mode=1
      shift
      if [[ $# -gt 0 ]]; then
        case "$1" in
          --*|exec) ;;
          *)
            zellij_tab_name="$1"
            shift
            ;;
        esac
      fi
      ;;
    --zellij-template)
      [[ $# -ge 2 ]] || die "codex_wp: --zellij-template requires a template key." 2
      zellij_mode=1
      zellij_template="$2"
      shift 2
      ;;
    --zellij-cwd)
      [[ $# -ge 2 ]] || die "codex_wp: --zellij-cwd requires a path." 2
      zellij_mode=1
      zellij_cwd="$2"
      shift 2
      ;;
    --zellij-dry-run)
      zellij_mode=1
      zellij_dry_run=1
      shift
      ;;
    -F|--zellij-floating)
      zellij_mode=1
      zellij_floating=1
      shift
      ;;
    --zellij-floating-pair)
      zellij_mode=1
      zellij_pair_mode=1
      shift
      ;;
    --pair-layout)
      [[ $# -ge 2 ]] || die "codex_wp: --pair-layout requires a layout key." 2
      zellij_pair_options_seen=1
      zellij_pair_layout="$2"
      shift 2
      ;;
    --a-prompt)
      [[ $# -ge 2 ]] || die "codex_wp: --a-prompt requires prompt text." 2
      zellij_pair_options_seen=1
      pair_a_prompt="$2"
      shift 2
      ;;
    --a-file)
      [[ $# -ge 2 ]] || die "codex_wp: --a-file requires a file path." 2
      zellij_pair_options_seen=1
      pair_a_file="$2"
      shift 2
      ;;
    --b-prompt)
      [[ $# -ge 2 ]] || die "codex_wp: --b-prompt requires prompt text." 2
      zellij_pair_options_seen=1
      pair_b_prompt="$2"
      shift 2
      ;;
    --b-file)
      [[ $# -ge 2 ]] || die "codex_wp: --b-file requires a file path." 2
      zellij_pair_options_seen=1
      pair_b_file="$2"
      shift 2
      ;;
    --zellij-pair-json)
      zellij_pair_options_seen=1
      zellij_pair_json=1
      shift
      ;;
    --zellij-top)
      [[ $# -ge 2 ]] || die "codex_wp: --zellij-top requires a value." 2
      zellij_mode=1
      zellij_floating=1
      zellij_top="$2"
      shift 2
      ;;
    --zellij-right)
      [[ $# -ge 2 ]] || die "codex_wp: --zellij-right requires a value." 2
      zellij_mode=1
      zellij_floating=1
      zellij_right="$2"
      shift 2
      ;;
    --zellij-width)
      [[ $# -ge 2 ]] || die "codex_wp: --zellij-width requires a value." 2
      zellij_mode=1
      zellij_floating=1
      zellij_float_width="$2"
      shift 2
      ;;
    --zellij-height)
      [[ $# -ge 2 ]] || die "codex_wp: --zellij-height requires a value." 2
      zellij_mode=1
      zellij_floating=1
      zellij_float_height="$2"
      shift 2
      ;;
    --zellij-close-on-exit)
      zellij_mode=1
      zellij_floating=1
      zellij_close_on_exit=1
      shift
      ;;
    -p|--prompt)
      if [[ -n "$(find_first_passthrough_token "${args[@]}")" ]]; then
        [[ $# -ge 2 ]] || die "codex_wp: $1 requires prompt text." 2
        args+=("$1" "$2")
        shift 2
        continue
      fi
      [[ $# -ge 2 ]] || die "codex_wp: $1 requires prompt text." 2
      prompt_shortcut="$2"
      shift 2
      ;;
    -SA)
      [[ -z "$fixed_shortcut" ]] || fixed_shortcut_error "-SA"
      fixed_shortcut="simplify_then_commit"
      shift
      ;;
    -A)
      [[ -z "$fixed_shortcut" ]] || fixed_shortcut_error "-A"
      fixed_shortcut="auto_commit"
      shift
      ;;
    -S)
      [[ -z "$fixed_shortcut" ]] || fixed_shortcut_error "-S"
      fixed_shortcut="code_simplifier"
      shift
      ;;
    --zellij-replace-existing)
      die "codex_wp: --zellij-replace-existing is not supported yet." 2
      ;;
    -f|--file)
      [[ $# -ge 2 ]] || die "codex_wp: $1 requires a file path." 2
      files_to_include+=("$2")
      shift 2
      ;;
    --hook)
      [[ $# -ge 2 ]] || die "codex_wp: --hook requires a value (stop)." 2
      hook_mode="$2"
      shift 2
      ;;
    --hook-prompt)
      [[ $# -ge 2 ]] || die "codex_wp: --hook-prompt requires prompt text." 2
      hook_prompt="$2"
      shift 2
      ;;
    --hook-time|--hook-times|--hook-max-turns)
      [[ $# -ge 2 ]] || die "codex_wp: $1 requires a number." 2
      hook_times="$2"
      shift 2
      ;;
    --hook-prompt-mode)
      [[ $# -ge 2 ]] || die "codex_wp: --hook-prompt-mode requires a value (static, auto, or hybrid)." 2
      hook_prompt_mode="$2"
      hook_prompt_mode_explicit=1
      shift 2
      ;;
    --hook-auto-stop-on-complete)
      hook_auto_stop_on_complete=1
      shift
      ;;
    --hook-target)
      [[ $# -ge 2 ]] || die "codex_wp: --hook-target requires a Telegram target." 2
      hook_target="$2"
      shift 2
      ;;
    --hook-delivery)
      [[ $# -ge 2 ]] || die "codex_wp: --hook-delivery requires a value (mattermost, telegram, both, or manager)." 2
      hook_delivery="$2"
      hook_delivery_explicit=1
      shift 2
      ;;
    --hook-last-message-format)
      [[ $# -ge 2 ]] || die "codex_wp: --hook-last-message-format requires a value (raw or ru3)." 2
      hook_last_message_format="$2"
      hook_last_message_format_explicit=1
      shift 2
      ;;
    --hook-supervision)
      [[ $# -ge 2 ]] || die "codex_wp: --hook-supervision requires a value." 2
      hook_supervision="$2"
      hook_supervision_explicit=1
      shift 2
      ;;
    --hook-extract-intent)
      hook_extract_intent=1
      shift
      ;;
    *)
      args+=("$1")
      shift
      ;;
  esac
done

if [[ -n "$fixed_shortcut" ]]; then
  case "$fixed_shortcut" in
    auto_commit)
      shortcut_flag="-A"
      shortcut_repo_error="codex_wp: -A requires a git repository. Run it from the repo you want to commit."
      shortcut_empty_message="codex_wp: nothing to commit in the current repository."
      ;;
    code_simplifier)
      shortcut_flag="-S"
      shortcut_repo_error="codex_wp: -S requires a git repository. Run it from the repo you want to simplify."
      shortcut_empty_message=""
      ;;
    simplify_then_commit)
      shortcut_flag="-SA"
      shortcut_repo_error="codex_wp: -SA requires a git repository. Run it from the repo you want to simplify and commit."
      shortcut_empty_message=""
      ;;
    *)
      die "codex_wp: unsupported fixed shortcut '$fixed_shortcut'."
      ;;
  esac

  if (( zellij_mode )) || (( zellij_pair_options_seen )) || (( ${#files_to_include[@]} > 0 )) || (( ${#args[@]} > 0 )); then
    fixed_shortcut_error "$shortcut_flag"
  fi

  git_is_inside_work_tree || die "$shortcut_repo_error" 2

  if [[ "$fixed_shortcut" == "auto_commit" ]] && ! git_worktree_has_changes; then
    printf '%s\n' "$shortcut_empty_message"
    exit 0
  fi

  zellij_mode=1
  zellij_floating=1
  zellij_close_on_exit=0
  fixed_shortcut_close_on_success=1
  zellij_float_name="$(fixed_shortcut_title "$fixed_shortcut")"
  if [[ "$fixed_shortcut" != "simplify_then_commit" ]]; then
    args=(
      exec
      "$(fixed_shortcut_prompt "$fixed_shortcut")"
    )
  else
    args=()
  fi
fi

help_requested=0
if is_help_request "${args[@]}"; then
  help_requested=1
fi

hook_requested_headless=0
if [[ -n "$prompt_shortcut" ]]; then
  hook_requested_headless=1
elif (( ${#args[@]} > 0 )) && [[ "${args[0]}" == "exec" || "${args[0]}" == "e" ]]; then
  hook_requested_headless=1
fi

validate_hook_flags() {
  if [[ -z "$hook_mode" ]]; then
    if [[ -n "$hook_prompt" || -n "$hook_times" || -n "$hook_target" || $hook_prompt_mode_explicit -eq 1 || $hook_auto_stop_on_complete -eq 1 || $hook_delivery_explicit -eq 1 || $hook_last_message_format_explicit -eq 1 || $hook_supervision_explicit -eq 1 || $hook_extract_intent -eq 1 ]]; then
      die \
        "codex_wp: --hook-prompt, --hook-times, --hook-prompt-mode, --hook-auto-stop-on-complete, --hook-target, --hook-delivery, --hook-last-message-format, --hook-supervision, and --hook-extract-intent require --hook stop." \
        2
    fi
    return 0
  fi

  [[ "$hook_mode" == "stop" ]] || die "codex_wp: --hook only supports 'stop'." 2
  if (( hook_supervision_explicit )); then
    hook_supervision="$(normalize_hook_supervision "$hook_supervision")" || \
      die "codex_wp: --hook-supervision only supports observation/management phrases." 2
    if (( hook_delivery_explicit )) && [[ "$hook_delivery" != "manager" ]]; then
      die "codex_wp: --hook-supervision only supports --hook-delivery manager." 2
    fi
    hook_delivery="manager"
  fi
  case "$hook_delivery" in
    telegram|mattermost|both|manager) ;;
    *)
      die "codex_wp: --hook-delivery only supports 'telegram', 'mattermost', 'both', or 'manager'." 2
      ;;
  esac
  case "$hook_last_message_format" in
    raw|ru3) ;;
    *)
      die "codex_wp: --hook-last-message-format only supports 'raw' or 'ru3'." 2
      ;;
  esac
  case "$hook_prompt_mode" in
    static|auto|hybrid) ;;
    *)
      die "codex_wp: --hook-prompt-mode only supports 'static', 'auto', or 'hybrid'." 2
      ;;
  esac
  if (( ! hook_requested_headless )) && [[ "$hook_prompt_mode" != "static" ]]; then
    die "codex_wp: --hook-prompt-mode auto/hybrid is only supported for headless 'exec --json' hook runs." 2
  fi
  if (( ! hook_requested_headless )) && (( hook_auto_stop_on_complete )); then
    die "codex_wp: --hook-auto-stop-on-complete is only supported for headless 'exec --json' hook runs." 2
  fi
  if (( hook_auto_stop_on_complete )) && [[ "$hook_prompt_mode" == "static" ]]; then
    die "codex_wp: --hook-auto-stop-on-complete requires --hook-prompt-mode auto or hybrid." 2
  fi
  if [[ "$hook_prompt_mode" == "static" ]]; then
    [[ -n "$hook_prompt" ]] || die "codex_wp: --hook stop requires --hook-prompt." 2
  elif [[ "$hook_prompt_mode" == "hybrid" ]]; then
    [[ -n "$hook_prompt" ]] || die "codex_wp: --hook-prompt-mode hybrid requires --hook-prompt for fallback." 2
  elif [[ -n "$hook_prompt" ]]; then
    die "codex_wp: --hook-prompt-mode auto does not use --hook-prompt. Remove it or use --hook-prompt-mode hybrid." 2
  fi
  [[ -n "$hook_times" ]] || die "codex_wp: --hook stop requires --hook-times." 2
  [[ "$hook_times" =~ ^[1-9][0-9]*$ ]] || \
    die "codex_wp: --hook-times must be a positive integer." 2
  if [[ "$hook_delivery" == "mattermost" && -n "$hook_target" ]]; then
    die "codex_wp: --hook-target requires telegram delivery (use telegram or both)." 2
  fi
  if [[ "$hook_delivery" == "manager" && -n "$hook_target" ]]; then
    die "codex_wp: --hook-target is only supported with --hook-delivery telegram or both." 2
  fi

  if (( zellij_mode )); then
    die "codex_wp: --hook is not supported with zellij launch modes yet." 2
  fi
}

if (( ! help_requested )); then
  validate_hook_flags
fi

if [[ -n "$prompt_shortcut" ]]; then
  if (( zellij_pair_mode )); then
    die "codex_wp: -p/--prompt is not supported with --zellij-floating-pair." 2
  fi
  if (( ${#args[@]} > 0 )) && [[ "${args[0]}" == "exec" || "${args[0]}" == "e" ]]; then
    die "codex_wp: -p/--prompt already implies 'exec --json'; remove explicit 'exec'." 2
  fi
  args=(exec --json "$prompt_shortcut" "${args[@]}")
fi

pair_shared_args=()
if (( ! help_requested )); then
  if (( zellij_pair_options_seen )) && (( ! zellij_pair_mode )); then
    die "codex_wp: --zellij-floating-pair is required when using pair flags." 2
  fi

  if (( zellij_pair_mode )); then
    if (( ${#files_to_include[@]} > 0 )); then
      die "codex_wp: pair mode does not accept --file before '--'. Pass shared inner flags after '--' instead." 2
    fi
    if (( ${#args[@]} > 0 )); then
      [[ "${args[0]}" == "--" ]] || \
        die "codex_wp: pair mode requires shared inner args after an explicit '--' delimiter." 2
      pair_shared_args=("${args[@]:1}")
    fi
    if (( ${#pair_shared_args[@]} > 0 )) && [[ "${pair_shared_args[0]}" == "exec" ]]; then
      die "codex_wp: pair mode adds 'exec' automatically. Remove it from the shared args." 2
    fi
    set --
  else
    set -- "${args[@]}"
  fi

  # Prepend file references to exec prompt if files were specified.
  # Root-level Codex options may legally appear before `exec`, so locate the subcommand first.
  if (( ! zellij_pair_mode )) && [[ ${#files_to_include[@]} -gt 0 ]]; then
    exec_subcommand_index="$(find_exec_subcommand_index "$@")"
  else
    exec_subcommand_index="-1"
  fi
  if (( ! zellij_pair_mode )) && [[ "$exec_subcommand_index" != "-1" ]]; then
    file_refs="$(build_file_refs "${files_to_include[@]}")"
    all_args=("$@")
    exec_prefix=("${all_args[@]:0:$((exec_subcommand_index + 1))}")
    exec_args=("${all_args[@]:$((exec_subcommand_index + 1))}")
    prompt_index="$(find_exec_prompt_index "${exec_args[@]}")"
    if [[ "$prompt_index" != "-1" ]]; then
      exec_args[$prompt_index]="${file_refs}${exec_args[$prompt_index]}"
    fi
    set -- "${exec_prefix[@]}" "${exec_args[@]}"
  fi
else
  set -- "${args[@]}"
fi

resolve_bin() {
  local candidate="$1"
  local fallback_name="$2"

  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  command -v "$fallback_name"
}

resolve_explicit_bin() {
  local candidate="$1"

  [[ -n "$candidate" && -x "$candidate" ]] || return 1
  printf '%s\n' "$candidate"
}

resolve_codex_bin() {
  if [[ -n "${CODEX_BIN:-}" ]]; then
    resolve_explicit_bin "${CODEX_BIN}"
    return $?
  fi

  command -v codex
}

resolve_cdx_bin() {
  if [[ -n "${CDX_BIN:-}" ]]; then
    resolve_explicit_bin "${CDX_BIN}"
    return $?
  fi

  resolve_bin "$repo_root/.venv/bin/cdx" "cdx"
}

print_codex_wp_wrapper_help() {
  cat <<'EOF'
codex_wp wrapper flags

These options are handled by codex_wp before arguments pass through to codex.
All non-wrapper flags pass through unchanged.

General wrapper flags:
  -p, --prompt <text>          shortcut: run 'exec --json <text>' headless
  -f, --file <path>            prepend @/absolute/path references to exec prompts
  -SA                          run built-in code-simplifier, then auto-commit, in one floating Zellij pane and close it on success
  -A                           run built-in auto-commit in a floating Zellij pane and close it on success
  -S                           run built-in code-simplifier in a floating Zellij pane and close it on success
  --zellij-new-tab [name]      open codex_wp in a new Zellij tab
  --zellij-template <key>      choose tab layout: single, three-horizontal, three-vertical
  --zellij-cwd <path>          override the working directory used for Zellij launch
  --zellij-dry-run             print the resolved Zellij command without launching it

Hook flags (interactive --hook stop is session-scoped; headless exec uses a wrapper loop):
  --hook stop                  enable stop hook handling
  --hook-prompt <text>         static resume prompt (required for static; fallback for hybrid)
  --hook-times <n>             how many stop events per session (requires --hook stop)
  --hook-time <n>              legacy alias for --hook-times
  --hook-max-turns <n>         alias for --hook-times
  --hook-prompt-mode <mode>    next prompt strategy: static|auto|hybrid (default: static)
  --hook-auto-stop-on-complete end early when auto mode says the task is complete
  --hook-supervision <mode>    headless exec --json only; manager delivery only; observation|management
  --hook-delivery <mode>       low-level transport override: mattermost|telegram|both|manager (default: mattermost)
  --hook-last-message-format <mode>
                               format last assistant message for Mattermost: raw|ru3
  --hook-target <target>       override Telegram target (telegram/both only)
  --hook-extract-intent        attach extract-intent summary to each notification

Floating pane flags:
  -F, --zellij-floating        launch codex_wp in a floating pane
  --zellij-top <value>         top offset for floating pane
  --zellij-right <value>       right offset for floating pane
  --zellij-width <value>       floating pane width
  --zellij-height <value>      floating pane height
  --zellij-close-on-exit       close the floating pane when the command exits

Floating pair flags:
  --zellij-floating-pair       launch two floating panes
  --pair-layout <key>          choose floating pair layout
  --a-prompt <text>            inline prompt for pane A
  --a-file <path>              prompt file for pane A
  --b-prompt <text>            inline prompt for pane B
  --b-file <path>              prompt file for pane B
  --zellij-pair-json           emit machine-readable pair launch output

Proxy companion commands:
  codex_wp auto-boots cdx proxy via `cdx proxy --print-env-only`
  cdx status --json            show proxy pid, base_url, and auth count
  cdx doctor --probe           probe auth keys and classify health
  cdx all                      show per-key 5h/weekly usage dashboard
  cdx rotate --dry-run         preview the next auth rotation
  cdx reset --state blacklist  clear stuck keys after auth fixes
  cdx trace --limit 20         tail recent routing events
  cdx logs --lines 50          tail proxy service logs
  cdx limits --tail 10         show persisted limits history

Zellij scrollback note:
  Inside Zellij, codex_wp automatically adds upstream `--no-alt-screen`.
  This keeps Codex in inline mode so pane scrollback keeps working.

Help is side-effect free. Wrapper help prints first, then upstream codex help.
EOF
}

if (( help_requested )); then
  if [[ $# -gt 0 && "$1" == "--" ]]; then
    shift
  fi
  (( $# > 0 )) || set -- --help

  print_codex_wp_wrapper_help
  printf '\n'
  if ! codex_bin="$(resolve_codex_bin)"; then
    if [[ -n "${CODEX_BIN:-}" ]]; then
      die "codex_wp: CODEX_BIN is set but not executable: ${CODEX_BIN}" 127
    fi
    die "codex_wp: codex not found. Install it or set CODEX_BIN." 127
  fi
  exec "$codex_bin" "$@"
fi

resolve_python_bin() {
  if [[ -n "${PYTHON_BIN:-}" ]]; then
    resolve_explicit_bin "${PYTHON_BIN}"
    return $?
  fi

  resolve_bin "$repo_root/.venv/bin/python3" "python3"
}

load_codex_wp_config_defaults() {
  local pythonpath
  local -a config_lines

  if ! codex_wp_python_bin="$(resolve_python_bin)"; then
    if [[ -n "${PYTHON_BIN:-}" ]]; then
      die "codex_wp: PYTHON_BIN is set but not executable: ${PYTHON_BIN}" 127
    fi
    die "codex_wp: python3 not found. Install it or set PYTHON_BIN." 127
  fi

  pythonpath="$repo_root/src"
  if [[ -n "${PYTHONPATH:-}" ]]; then
    pythonpath="$pythonpath:$PYTHONPATH"
  fi

  mapfile -t config_lines < <(
    PYTHONPATH="$pythonpath" "$codex_wp_python_bin" - <<'PY'
from cdx_proxy_cli_v2.config.settings import load_codex_wp_defaults

defaults = load_codex_wp_defaults()
print(defaults["zellij_float_top"])
print(defaults["zellij_float_right"])
print(defaults["zellij_float_width"])
print(defaults["zellij_float_height"])
print("true" if defaults["zellij_float_close_on_exit"] else "false")
print("true" if defaults["zellij_float_pinned"] else "false")
print(defaults["zellij_float_name"])
print(defaults["zellij_float_title_prefix"])
print(defaults["zellij_pair_layout"])
print(defaults["zellij_pair_top"])
print(defaults["zellij_pair_right"])
print(defaults["zellij_pair_width"])
print(defaults["zellij_pair_height"])
print(defaults["zellij_pair_gap"])
print("true" if defaults["zellij_auto_name"] else "false")
print(defaults["zellij_title_max_words"])
print(defaults["zellij_title_case"])
print(defaults["zellij_title_fallback"])
PY
  )

  [[ ${#config_lines[@]} -eq 18 ]] || die "codex_wp: failed to load codex_wp config defaults."

  [[ -n "$zellij_top" ]] || zellij_top="${config_lines[0]}"
  [[ -n "$zellij_right" ]] || zellij_right="${config_lines[1]}"
  [[ -n "$zellij_float_width" ]] || zellij_float_width="${config_lines[2]}"
  [[ -n "$zellij_float_height" ]] || zellij_float_height="${config_lines[3]}"
  if [[ -z "$zellij_close_on_exit" ]]; then
    if [[ "${config_lines[4]}" == "true" ]]; then
      zellij_close_on_exit=1
    else
      zellij_close_on_exit=0
    fi
  fi
  zellij_pinned="${config_lines[5]}"
  [[ -n "$zellij_float_name" ]] || zellij_float_name="${config_lines[6]}"
  zellij_float_title_prefix="${config_lines[7]}"
  [[ -n "$zellij_pair_layout" ]] || zellij_pair_layout="${config_lines[8]}"
  [[ -n "$zellij_pair_top" ]] || zellij_pair_top="${config_lines[9]}"
  [[ -n "$zellij_pair_right" ]] || zellij_pair_right="${config_lines[10]}"
  [[ -n "$zellij_pair_width" ]] || zellij_pair_width="${config_lines[11]}"
  [[ -n "$zellij_pair_height" ]] || zellij_pair_height="${config_lines[12]}"
  [[ -n "$zellij_pair_gap" ]] || zellij_pair_gap="${config_lines[13]}"
  zellij_auto_name="${config_lines[14]}"
  zellij_title_max_words="${config_lines[15]}"
  zellij_title_case="${config_lines[16]}"
  zellij_title_fallback="${config_lines[17]}"
}

derive_zellij_cwd() {
  local inner_args=("$@")
  local derived_cwd=""
  local index

  if [[ -n "$zellij_cwd" ]]; then
    printf '%s\n' "$zellij_cwd"
    return 0
  fi

  for ((index = 0; index < ${#inner_args[@]}; index++)); do
    if [[ "${inner_args[$index]}" == "-C" ]] && (( index + 1 < ${#inner_args[@]} )); then
      derived_cwd="${inner_args[$((index + 1))]}"
      ((index++))
    fi
  done

  if [[ -n "$derived_cwd" ]]; then
    printf '%s\n' "$derived_cwd"
    return 0
  fi

  printf '%s\n' "$PWD"
}

read_zellij_tabs_json() {
  local include_dimensions="${1:-0}"
  local stderr_path
  local tabs_output
  local -a command_args

  stderr_path="$(mktemp)"
  command_args=("$zellij_bin" action list-tabs --json)
  if (( include_dimensions )); then
    command_args+=(--state --dimensions)
  fi

  if ! tabs_output="$("${command_args[@]}" 2>"$stderr_path")"; then
    zellij_error="$(tr '\n' ' ' <"$stderr_path" | sed 's/[[:space:]]*$//')"
    rm -f "$stderr_path"
    if [[ -n "$zellij_error" ]]; then
      die "codex_wp: no active zellij session found. $zellij_error"
    fi
    die "codex_wp: no active zellij session found."
  fi
  rm -f "$stderr_path"
  printf '%s\n' "$tabs_output"
}

resolve_floating_geometry() {
  LIST_TABS_OUTPUT="$1" "$codex_wp_python_bin" - \
    "$zellij_top" \
    "$zellij_right" \
    "$zellij_float_width" \
    "$zellij_float_height" <<'PY'
import json
import os
import sys


def parse_measure(raw, total, *, allow_zero):
    text = str(raw).strip()
    if not text:
        raise ValueError("empty measure")
    if text.endswith("%"):
        percent = float(text[:-1])
        value = int(round((total * percent) / 100.0))
    else:
        value = int(text)
    minimum = 0 if allow_zero else 1
    return max(minimum, value)


tabs = json.loads(os.environ["LIST_TABS_OUTPUT"])
if not isinstance(tabs, list) or not tabs:
    raise SystemExit(2)

active = next((item for item in tabs if isinstance(item, dict) and item.get("active")), None)
if active is None:
    active = next((item for item in tabs if isinstance(item, dict)), None)
if active is None:
    raise SystemExit(2)

columns = int(active.get("viewport_columns") or active.get("display_area_columns") or 0)
rows = int(active.get("viewport_rows") or active.get("display_area_rows") or 0)
if columns <= 0 or rows <= 0:
    raise SystemExit(2)

top = parse_measure(sys.argv[1], rows, allow_zero=True)
right = parse_measure(sys.argv[2], columns, allow_zero=True)
width = parse_measure(sys.argv[3], columns, allow_zero=False)
height = parse_measure(sys.argv[4], rows, allow_zero=False)
x = max(0, columns - width - right)
y = max(0, top)

print(x, y, width, height)
PY
}

extract_prompt_text() {
  local inner_args=("$@")
  local last_index

  if [[ ${#inner_args[@]} -eq 0 ]]; then
    return 1
  fi

  last_index=$((${#inner_args[@]} - 1))
  printf '%s\n' "${inner_args[$last_index]}"
}

resolve_zellij_name() {
  local explicit_name="$1"
  shift
  local prompt_text=""

  if [[ -n "$explicit_name" ]]; then
    printf '%s\n' "$explicit_name"
    return 0
  fi

  if [[ "$zellij_auto_name" != "true" ]]; then
    printf '%s\n' "$zellij_title_fallback"
    return 0
  fi

  if prompt_text="$(extract_prompt_text "$@")"; then
    CODEX_WP_PROMPT="$prompt_text" "$codex_wp_python_bin" - \
      "$zellij_title_max_words" \
      "$zellij_title_case" \
      "$zellij_title_fallback" <<'PY'
import os
import re
import sys
import unicodedata
from pathlib import Path


STOP_WORDS = {
    "a",
    "an",
    "and",
    "analyze",
    "as",
    "at",
    "be",
    "by",
    "can",
    "create",
    "debug",
    "do",
    "document",
    "does",
    "exactly",
    "explain",
    "for",
    "from",
    "fix",
    "give",
    "implement",
    "in",
    "into",
    "investigate",
    "is",
    "it",
    "make",
    "of",
    "on",
    "only",
    "or",
    "output",
    "plan",
    "please",
    "print",
    "reply",
    "respond",
    "return",
    "run",
    "show",
    "start",
    "stop",
    "summarize",
    "tell",
    "test",
    "the",
    "this",
    "to",
    "use",
    "using",
    "validate",
    "with",
    "write",
}

ACTION_LABELS = {
    "add": "Build",
    "analyze": "Analysis",
    "audit": "Review",
    "build": "Build",
    "check": "Check",
    "create": "Build",
    "debug": "Debug",
    "design": "Plan",
    "document": "Docs",
    "explain": "Explain",
    "fix": "Fix",
    "implement": "Build",
    "investigate": "Debug",
    "plan": "Plan",
    "refactor": "Refactor",
    "repair": "Fix",
    "review": "Review",
    "summarize": "Summary",
    "test": "Check",
    "validate": "Check",
    "verify": "Check",
}

GENERIC_SUBJECTS = {
    "bug",
    "check",
    "command",
    "flow",
    "issue",
    "output",
    "problem",
    "prompt",
    "script",
    "task",
}

IGNORE_MARKER_TOKENS = {"DONE", "OK", "PASS", "STOP"}


def unique_words(words: list[str]) -> list[str]:
    seen: set[str] = set()
    result: list[str] = []
    for word in words:
        key = word.lower()
        if key in seen:
            continue
        seen.add(key)
        result.append(word)
    return result


def detect_math_title(line: str) -> list[str] | None:
    if re.search(r"[A-Za-z]", line):
        return None
    if re.search(r"\d", line) and re.search(r"[+\-*/%=^]", line):
        return ["Math", "Check"]
    return None


def detect_exact_reply_title(line: str) -> list[str] | None:
    match = re.search(
        r"\b(?:reply|respond|print|return)\b.*?\bexactly\b\s+([A-Z][A-Z0-9_-]{1,})\b",
        line,
        flags=re.IGNORECASE,
    )
    if not match:
        return None
    marker = match.group(1).upper()
    if marker in IGNORE_MARKER_TOKENS:
        return None
    return [marker, "Check"]


def extract_path_tokens(line: str) -> list[str]:
    tokens: list[str] = []
    for raw_path in re.findall(r"@(\S+)", line):
        stem = Path(raw_path).stem
        tokens.extend(re.findall(r"[A-Za-z0-9]+", stem))
    return tokens


def select_action_label(line: str) -> str | None:
    lowered_tokens = re.findall(r"[A-Za-z]+", line.lower())
    for token in lowered_tokens:
        label = ACTION_LABELS.get(token)
        if label:
            return label
    return None


def collect_subject_tokens(line: str, path_tokens: list[str], action_label: str | None) -> list[str]:
    combined = path_tokens + re.findall(r"[A-Za-z0-9]+", line)
    filtered: list[str] = []
    for token in combined:
        lowered = token.lower()
        if lowered in STOP_WORDS or lowered in ACTION_LABELS:
            continue
        if len(token) == 1 and not token.isdigit():
            continue
        if token.isdigit():
            continue
        filtered.append(token)

    subjects = unique_words(filtered)
    if action_label:
        tightened = [token for token in subjects if token.lower() not in GENERIC_SUBJECTS]
        if tightened:
            subjects = tightened
    return subjects


def normalize_token(token: str, mode: str) -> str:
    if not token:
        return token
    if mode == "upper":
        return token.upper()
    if mode == "lower":
        return token.lower()
    if token.isupper() or any(char.isdigit() for char in token):
        return token.upper()
    return token[:1].upper() + token[1:].lower()


def apply_case(words: list[str], mode: str) -> list[str]:
    lowered = mode.strip().lower()
    if lowered == "sentence":
        sentence_words = [word.lower() for word in words]
        sentence_words[0] = normalize_token(sentence_words[0], "title")
        return sentence_words
    return [normalize_token(word, lowered) for word in words]


fallback = str(sys.argv[3] or "").strip() or "Codex Task"
raw_prompt = unicodedata.normalize("NFKC", os.environ.get("CODEX_WP_PROMPT", ""))
first_line = raw_prompt.splitlines()[0] if raw_prompt else ""
without_refs = re.sub(r"@\S+", " ", first_line)
max_words = max(1, int(sys.argv[1] or "1"))
path_tokens = extract_path_tokens(first_line)
selected = detect_math_title(without_refs) or detect_exact_reply_title(without_refs)
if selected is None:
    action_label = select_action_label(without_refs)
    subjects = collect_subject_tokens(without_refs, path_tokens, action_label)
    if len(subjects) >= max_words:
        selected = subjects[:max_words]
    elif action_label and subjects:
        selected = (subjects + [action_label])[:max_words]
    elif subjects:
        selected = subjects[:max_words]
    elif action_label:
        selected = [action_label, "Task"][:max_words]
    else:
        selected = []

if not selected:
    print(fallback)
    raise SystemExit(0)

print(" ".join(apply_case(selected, sys.argv[2])))
PY
    return 0
  fi

  printf '%s\n' "$zellij_title_fallback"
}

apply_floating_title_prefix() {
  local name="$1"
  local prefix="$zellij_float_title_prefix"
  local separator=" "

  if [[ -z "$name" || -z "$prefix" ]]; then
    printf '%s\n' "$name"
    return 0
  fi

  if [[ "$name" == "$prefix" || "$name" == "$prefix "* || "$name" == "$prefix"* ]]; then
    printf '%s\n' "$name"
    return 0
  fi

  if [[ "$prefix" == *[[:space:]] ]]; then
    separator=""
  fi

  printf '%s%s%s\n' "$prefix" "$separator" "$name"
}

resolve_initial_floating_name() {
  local final_name="$1"

  if [[ -n "$zellij_float_name" ]]; then
    printf '%s\n' "$final_name"
    return 0
  fi

  if [[ -n "$zellij_float_title_prefix" ]]; then
    printf '%s\n' "$zellij_float_title_prefix"
    return 0
  fi

  printf '%s\n' "$final_name"
}

init_zellij_floating_run_command() {
  local output_var="$1"
  local executable="$2"
  local -n command_ref="$output_var"

  command_ref=(
    "$executable"
    run
    --floating
  )
  if (( zellij_close_on_exit )); then
    command_ref+=(--close-on-exit)
  fi
  if [[ "$zellij_pinned" == "true" ]]; then
    command_ref+=(--pinned true)
  fi
}

load_prompt_text_from_file() {
  local output_var="$1"
  local slot="$2"
  local prompt_file="$3"
  local prompt_text=""

  [[ -f "$prompt_file" ]] || die "codex_wp: $slot prompt file not found: $prompt_file" 2
  [[ -r "$prompt_file" ]] || die "codex_wp: $slot prompt file is not readable: $prompt_file" 2

  if ! IFS= read -r -d '' prompt_text < <(
    "$codex_wp_python_bin" - "$prompt_file" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
sys.stdout.write(path.read_text(encoding="utf-8"))
sys.stdout.write("\0")
PY
  ); then
    die "codex_wp: failed to read $slot prompt file '$prompt_file' as UTF-8 text." 2
  fi

  printf -v "$output_var" '%s' "$prompt_text"
}

resolve_pair_prompt_text() {
  local output_var="$1"
  local slot="$2"
  local inline_prompt="$3"
  local prompt_file="$4"

  if [[ -n "$inline_prompt" && -n "$prompt_file" ]]; then
    die "codex_wp: $slot requires exactly one of inline prompt or prompt file." 2
  fi
  if [[ -z "$inline_prompt" && -z "$prompt_file" ]]; then
    die "codex_wp: $slot prompt source is required." 2
  fi

  if [[ -n "$prompt_file" ]]; then
    load_prompt_text_from_file "$output_var" "$slot" "$prompt_file"
    return 0
  fi

  printf -v "$output_var" '%s' "$inline_prompt"
}

resolve_pair_geometry() {
  LIST_TABS_OUTPUT="$1" "$codex_wp_python_bin" - \
    "$zellij_pair_layout" \
    "$zellij_pair_top" \
    "$zellij_pair_right" \
    "$zellij_pair_width" \
    "$zellij_pair_height" \
    "$zellij_pair_gap" <<'PY'
import json
import os
import sys


def parse_measure(raw, total, *, allow_zero):
    text = str(raw).strip()
    if not text:
        raise ValueError("empty measure")
    if text.endswith("%"):
        percent = float(text[:-1])
        value = int(round((total * percent) / 100.0))
    else:
        value = int(text)
    minimum = 0 if allow_zero else 1
    return max(minimum, value)


def parse_gap(raw):
    gap = int(str(raw).strip())
    if gap < 0:
        raise ValueError("negative gap")
    return gap


layout = sys.argv[1]
if layout != "top-right-double":
    raise SystemExit(3)

tabs = json.loads(os.environ["LIST_TABS_OUTPUT"])
if not isinstance(tabs, list) or not tabs:
    raise SystemExit(2)

active = next((item for item in tabs if isinstance(item, dict) and item.get("active")), None)
if active is None:
    active = next((item for item in tabs if isinstance(item, dict)), None)
if active is None:
    raise SystemExit(2)

columns = int(active.get("viewport_columns") or active.get("display_area_columns") or 0)
rows = int(active.get("viewport_rows") or active.get("display_area_rows") or 0)
if columns <= 0 or rows <= 0:
    raise SystemExit(2)

top = parse_measure(sys.argv[2], rows, allow_zero=True)
right = parse_measure(sys.argv[3], columns, allow_zero=True)
width = parse_measure(sys.argv[4], columns, allow_zero=False)
total_height = parse_measure(sys.argv[5], rows, allow_zero=False)
gap = parse_gap(sys.argv[6])
available_height = total_height - gap
if available_height < 2:
    raise SystemExit(4)

height_a = available_height // 2
height_b = available_height - height_a
if height_a <= 0 or height_b <= 0:
    raise SystemExit(4)

x = max(0, columns - width - right)
y_a = max(0, top)
y_b = y_a + height_a + gap

print(x, y_a, width, height_a, x, y_b, width, height_b)
PY
}

resolve_pair_initial_name() {
  local slot="$1"

  if [[ -n "$zellij_float_title_prefix" ]]; then
    printf '%s%s\n' "$zellij_float_title_prefix" "$slot"
    return 0
  fi

  printf '%s\n' "$slot"
}

emit_pair_result() {
  local pane_a_id="$1"
  local pane_a_initial_title="$2"
  local pane_a_final_title="$3"
  local pane_a_state="$4"
  local pane_a_command="$5"
  local pane_b_id="$6"
  local pane_b_initial_title="$7"
  local pane_b_final_title="$8"
  local pane_b_state="$9"
  local pane_b_command="${10}"

  if (( zellij_pair_json )); then
    PAIR_LAYOUT="$zellij_pair_layout" \
    PAIR_DRY_RUN="$zellij_dry_run" \
    PANE_A_ID="$pane_a_id" \
    PANE_A_INITIAL_TITLE="$pane_a_initial_title" \
    PANE_A_FINAL_TITLE="$pane_a_final_title" \
    PANE_A_STATE="$pane_a_state" \
    PANE_A_COMMAND="$pane_a_command" \
    PANE_B_ID="$pane_b_id" \
    PANE_B_INITIAL_TITLE="$pane_b_initial_title" \
    PANE_B_FINAL_TITLE="$pane_b_final_title" \
    PANE_B_STATE="$pane_b_state" \
    PANE_B_COMMAND="$pane_b_command" \
      "$codex_wp_python_bin" - <<'PY'
import json
import os


def pane(slot: str):
    upper = slot.upper()
    payload = {
        "slot": slot,
        "pane_id": os.environ.get(f"PANE_{upper}_ID") or None,
        "initial_title": os.environ.get(f"PANE_{upper}_INITIAL_TITLE") or None,
        "final_title": os.environ.get(f"PANE_{upper}_FINAL_TITLE") or None,
        "state": os.environ.get(f"PANE_{upper}_STATE") or None,
    }
    command = os.environ.get(f"PANE_{upper}_COMMAND") or ""
    if command:
        payload["launch_command"] = command
    return payload


print(
    json.dumps(
        {
            "mode": "zellij-floating-pair",
            "layout": os.environ["PAIR_LAYOUT"],
            "dry_run": os.environ.get("PAIR_DRY_RUN") == "1",
            "panes": [pane("a"), pane("b")],
        }
    )
)
PY
    return 0
  fi

  printf 'mode=zellij-floating-pair layout=%s\n' "$zellij_pair_layout"
  printf \
    'pane[a]=%s title="%s" state=%s\n' \
    "${pane_a_id:-none}" \
    "$pane_a_final_title" \
    "$pane_a_state"
  if [[ -n "$pane_a_command" ]]; then
    printf 'pane[a].command=%s\n' "$pane_a_command"
  fi
  printf \
    'pane[b]=%s title="%s" state=%s\n' \
    "${pane_b_id:-none}" \
    "$pane_b_final_title" \
    "$pane_b_state"
  if [[ -n "$pane_b_command" ]]; then
    printf 'pane[b].command=%s\n' "$pane_b_command"
  fi
}

if (( zellij_mode )); then
  layout_path="$repo_root/layouts/zellij/$zellij_template.kdl"
  zellij_bin="$(command -v zellij || true)"

  [[ -n "$zellij_bin" && -x "$zellij_bin" ]] || \
    die "codex_wp: zellij not found. Install it or set PATH." 127

  load_codex_wp_config_defaults

  if (( zellij_pair_mode )) && ((( zellij_floating )) || (( zellij_new_tab_requested ))); then
    die "codex_wp: --zellij-floating-pair cannot be combined with other zellij launch modes." 2
  fi

  if (( zellij_floating )) && (( zellij_new_tab_requested )); then
    die "codex_wp: --zellij-floating cannot be combined with --zellij-new-tab." 2
  fi

  if (( zellij_pair_mode )); then
    case "$zellij_pair_layout" in
      top-right-double) ;;
      *)
        die \
          "codex_wp: unknown pair layout '$zellij_pair_layout'. Valid layouts: top-right-double." \
          2
        ;;
    esac

    resolve_pair_prompt_text prompt_a_text "pane A" "$pair_a_prompt" "$pair_a_file"
    resolve_pair_prompt_text prompt_b_text "pane B" "$pair_b_prompt" "$pair_b_file"

    list_tabs_output="$(read_zellij_tabs_json 1)"
    pair_geometry_output="$(resolve_pair_geometry "$list_tabs_output")" || \
      die "codex_wp: failed to resolve pair zellij geometry."
    read -r \
      pair_a_x \
      pair_a_y \
      pair_a_width \
      pair_a_height \
      pair_b_x \
      pair_b_y \
      pair_b_width \
      pair_b_height <<<"$pair_geometry_output"

    resolved_zellij_cwd="$(derive_zellij_cwd "${pair_shared_args[@]}")"
    final_title_a="$(resolve_zellij_name "" exec "${pair_shared_args[@]}" "$prompt_a_text")"
    final_title_b="$(resolve_zellij_name "" exec "${pair_shared_args[@]}" "$prompt_b_text")"
    final_title_a="$(apply_floating_title_prefix "$final_title_a")"
    final_title_b="$(apply_floating_title_prefix "$final_title_b")"
    initial_title_a="$(resolve_pair_initial_name "a")"
    initial_title_b="$(resolve_pair_initial_name "b")"

    inner_command_a=("$script_path" exec "${pair_shared_args[@]}" "$prompt_a_text")
    inner_command_b=("$script_path" exec "${pair_shared_args[@]}" "$prompt_b_text")
    init_zellij_floating_run_command zellij_command_a "$zellij_bin"
    init_zellij_floating_run_command zellij_command_b "$zellij_bin"
    init_zellij_floating_run_command zellij_display_command_a zellij
    init_zellij_floating_run_command zellij_display_command_b zellij
    zellij_command_a+=(
      --cwd "$resolved_zellij_cwd"
      --name "$initial_title_a"
      --x "$pair_a_x"
      --y "$pair_a_y"
      --width "$pair_a_width"
      --height "$pair_a_height"
      --
      "${inner_command_a[@]}"
    )
    zellij_command_b+=(
      --cwd "$resolved_zellij_cwd"
      --name "$initial_title_b"
      --x "$pair_b_x"
      --y "$pair_b_y"
      --width "$pair_b_width"
      --height "$pair_b_height"
      --
      "${inner_command_b[@]}"
    )
    zellij_display_command_a+=(
      --cwd "$resolved_zellij_cwd"
      --name "$final_title_a"
      --x "$pair_a_x"
      --y "$pair_a_y"
      --width "$pair_a_width"
      --height "$pair_a_height"
      --
      "${inner_command_a[@]}"
    )
    zellij_display_command_b+=(
      --cwd "$resolved_zellij_cwd"
      --name "$final_title_b"
      --x "$pair_b_x"
      --y "$pair_b_y"
      --width "$pair_b_width"
      --height "$pair_b_height"
      --
      "${inner_command_b[@]}"
    )

    pane_a_command_string="$(build_shell_command_string "${zellij_display_command_a[@]}")"
    pane_b_command_string="$(build_shell_command_string "${zellij_display_command_b[@]}")"

    if (( zellij_dry_run )); then
      emit_pair_result \
        "" \
        "$initial_title_a" \
        "$final_title_a" \
        "planned" \
        "$pane_a_command_string" \
        "" \
        "$initial_title_b" \
        "$final_title_b" \
        "planned" \
        "$pane_b_command_string"
      exit 0
    fi

    pane_a_id=""
    pane_b_id=""
    pane_a_state="failed"
    pane_b_state="failed"

    if ! pane_a_id="$("${zellij_command_a[@]}")"; then
      die "codex_wp: failed to create pane A for pair mode."
    fi
    pane_a_state="created"
    if [[ -n "$pane_a_id" && "$initial_title_a" != "$final_title_a" ]]; then
      if "$zellij_bin" action rename-pane --pane-id "$pane_a_id" "$final_title_a" >/dev/null; then
        pane_a_state="renamed"
      else
        pane_a_state="rename_failed"
      fi
    else
      pane_a_state="renamed"
    fi

    if ! pane_b_id="$("${zellij_command_b[@]}")"; then
      emit_pair_result \
        "$pane_a_id" \
        "$initial_title_a" \
        "$final_title_a" \
        "$pane_a_state" \
        "" \
        "" \
        "$initial_title_b" \
        "$final_title_b" \
        "failed" \
        ""
      exit 3
    fi
    pane_b_state="created"
    if [[ -n "$pane_b_id" && "$initial_title_b" != "$final_title_b" ]]; then
      if "$zellij_bin" action rename-pane --pane-id "$pane_b_id" "$final_title_b" >/dev/null; then
        pane_b_state="renamed"
      else
        pane_b_state="rename_failed"
      fi
    else
      pane_b_state="renamed"
    fi

    emit_pair_result \
      "$pane_a_id" \
      "$initial_title_a" \
      "$final_title_a" \
      "$pane_a_state" \
      "" \
      "$pane_b_id" \
      "$initial_title_b" \
      "$final_title_b" \
      "$pane_b_state" \
      ""
    exit 0
  fi

  if (( zellij_floating )); then
    list_tabs_output="$(read_zellij_tabs_json 1)"
    geometry_output="$(resolve_floating_geometry "$list_tabs_output")" || \
      die "codex_wp: failed to resolve floating zellij geometry."
    read -r float_x float_y float_width float_height <<<"$geometry_output"

    resolved_zellij_cwd="$(derive_zellij_cwd "$@")"
    resolved_zellij_name="$(resolve_zellij_name "$zellij_float_name" "$@")"
    resolved_zellij_name="$(apply_floating_title_prefix "$resolved_zellij_name")"
    initial_zellij_name="$(resolve_initial_floating_name "$resolved_zellij_name")"
    inner_command=("$script_path" "$@")
    if [[ "$fixed_shortcut" == "simplify_then_commit" ]]; then
      build_simplify_then_commit_inner_command inner_command
    elif (( fixed_shortcut_close_on_success )); then
      build_close_on_success_inner_command inner_command "$shortcut_flag" "${inner_command[@]}"
    fi
    init_zellij_floating_run_command zellij_command "$zellij_bin"
    init_zellij_floating_run_command zellij_display_command zellij
    zellij_command+=(
      --cwd "$resolved_zellij_cwd"
      --name "$initial_zellij_name"
      --x "$float_x"
      --y "$float_y"
      --width "$float_width"
      --height "$float_height"
      --
      "${inner_command[@]}"
    )
    zellij_display_command+=(
      --cwd "$resolved_zellij_cwd"
      --name "$resolved_zellij_name"
      --x "$float_x"
      --y "$float_y"
      --width "$float_width"
      --height "$float_height"
      --
      "${inner_command[@]}"
    )

    if (( zellij_dry_run )); then
      printf \
        'floating=top=%s right=%s width=%s height=%s close_on_exit=%s\n' \
        "$zellij_top" \
        "$zellij_right" \
        "$zellij_float_width" \
        "$zellij_float_height" \
        "$([[ $zellij_close_on_exit -eq 1 ]] && printf 'true' || printf 'false')"
      print_shell_command "${zellij_display_command[@]}"
      exit 0
    fi

    created_pane_id="$("${zellij_command[@]}")"
    if [[ -n "$created_pane_id" && "$initial_zellij_name" != "$resolved_zellij_name" ]]; then
      "$zellij_bin" action rename-pane --pane-id "$created_pane_id" "$resolved_zellij_name" >/dev/null
    fi
    printf '%s\n' "$created_pane_id"
    exit 0
  fi

  (( zellij_new_tab_requested )) || \
    die "codex_wp: --zellij-new-tab is required when using zellij mode." 2

  case "$zellij_template" in
    single|three-horizontal|three-vertical) ;;
    *)
      die \
        "codex_wp: unknown zellij template '$zellij_template'. Valid templates: single, three-horizontal, three-vertical." \
        2
      ;;
  esac

  [[ -f "$layout_path" ]] || die "codex_wp: zellij template file not found: $layout_path"

  zellij_tab_name="$(resolve_zellij_name "$zellij_tab_name" "$@")"
  list_tabs_output="$(read_zellij_tabs_json 0)"

  if LIST_TABS_OUTPUT="$list_tabs_output" "$codex_wp_python_bin" - "$zellij_tab_name" <<'PY'
import json
import os
import sys

target = sys.argv[1]

try:
    payload = json.loads(os.environ["LIST_TABS_OUTPUT"])
except Exception:
    raise SystemExit(2)

if not isinstance(payload, list):
    raise SystemExit(2)

for item in payload:
    if isinstance(item, dict) and str(item.get("name") or "") == target:
        raise SystemExit(0)

raise SystemExit(1)
PY
  then
    die "codex_wp: zellij tab '$zellij_tab_name' already exists."
  else
    parse_status=$?
    if [[ $parse_status -ne 1 ]]; then
      die "codex_wp: failed to parse zellij tab list."
    fi
  fi

  resolved_zellij_cwd="$(derive_zellij_cwd "$@")"
  inner_command=("$script_path" "$@")
  zellij_command=(
    "$zellij_bin"
    action
    new-tab
    --name "$zellij_tab_name"
    --cwd "$resolved_zellij_cwd"
    --layout "$layout_path"
    --
    "${inner_command[@]}"
  )
  zellij_display_command=(
    zellij
    action
    new-tab
    --name "$zellij_tab_name"
    --cwd "$resolved_zellij_cwd"
    --layout "$layout_path"
    --
    "${inner_command[@]}"
  )

  if (( zellij_dry_run )); then
    printf 'layout=%s\n' "$layout_path"
    print_shell_command "${zellij_display_command[@]}"
    exit 0
  fi

  exec "${zellij_command[@]}"
fi

array_has() {
  local needle="$1"
  shift
  local item

  for item in "$@"; do
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done

  return 1
}

hook_is_headless_mode() {
  [[ $# -gt 0 ]] || return 1
  case "$1" in
    exec|e)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

hook_is_interactive_mode() {
  [[ $# -eq 0 ]] && return 0
  case "$1" in
    exec|e|review|help)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

hook_resolve_project_root_from_args() {
  local inner_args=("$@")
  local derived_root="$PWD"
  local index=0
  local arg=""

  while (( index < ${#inner_args[@]} )); do
    arg="${inner_args[$index]}"
    case "$arg" in
      -C|--cd)
        if (( index + 1 < ${#inner_args[@]} )); then
          derived_root="${inner_args[$((index + 1))]}"
          ((index+=2))
          continue
        fi
        ;;
      --cd=*)
        derived_root="${arg#--cd=}"
        ;;
    esac
    ((index++))
  done

  if [[ "$derived_root" == /* ]]; then
    printf '%s\n' "$derived_root"
  else
    printf '%s\n' "$PWD/$derived_root"
  fi
}

hook_python_bin() {
  if [[ -z "$codex_wp_python_bin" ]]; then
    if ! codex_wp_python_bin="$(resolve_python_bin)"; then
      if [[ -n "${PYTHON_BIN:-}" ]]; then
        die "codex_wp: PYTHON_BIN is set but not executable: ${PYTHON_BIN}" 127
      fi
      die "codex_wp: python3 not found. Install it or set PYTHON_BIN." 127
    fi
  fi
  [[ -n "$codex_wp_python_bin" && -x "$codex_wp_python_bin" ]] || \
    die "codex_wp: python3 not found. Install it or set PYTHON_BIN." 127
  printf '%s\n' "$codex_wp_python_bin"
}

hook_require_headless_preconditions() {
  [[ $# -gt 0 ]] || return 0

  if [[ $# -gt 1 && "$2" == "resume" ]]; then
    die "codex_wp: --hook stop does not support manual 'exec resume'. Start with 'exec' and let the wrapper manage resumes." 2
  fi

  array_has --json "$@" || \
    die "codex_wp: headless --hook stop requires 'exec --json' so session metadata can be parsed." 2

  if array_has --ephemeral "$@"; then
    die "codex_wp: headless --hook stop does not support --ephemeral because resume requires a persisted session." 2
  fi
}

hook_resolve_cli() {
  command -v cdx-hook || true
}

hook_project_has_managed_state() {
  local project_root="${1:-$PWD}"
  local python_bin=""
  python_bin="$(hook_python_bin)"

  "$python_bin" - "$project_root" <<'PY' 2>/dev/null
import json
import sys
from pathlib import Path

project_root = Path(sys.argv[1])
codex_dir = project_root / ".codex"
settings_path = codex_dir / "cdx-hook.json"
wrapper_path = codex_dir / "hooks" / "cdx_hook_stop_handler.py"
hooks_path = codex_dir / "hooks.json"

if settings_path.exists() or wrapper_path.exists():
    raise SystemExit(0)
if not hooks_path.exists():
    raise SystemExit(1)

try:
    payload = json.loads(hooks_path.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(1)

stop_groups = payload.get("hooks", {}).get("Stop")
if not isinstance(stop_groups, list):
    raise SystemExit(1)

for group in stop_groups:
    if isinstance(group, dict) and group.get("_managed_by") == "cdx-hook":
        raise SystemExit(0)

raise SystemExit(1)
PY
}

hook_inline_disable_project_managed_stop() {
  local project_root="${1:-$PWD}"
  local python_bin=""
  python_bin="$(hook_python_bin)"

  "$python_bin" - "$project_root" <<'PY'
import json
import sys
from pathlib import Path

OWNED_CONFIG_TOML = (
    "# Managed by cdx-hook. Remove this file only if you no longer need Codex hooks.\n"
    "[features]\n"
    "codex_hooks = true\n"
)

project_root = Path(sys.argv[1])
codex_dir = project_root / ".codex"
hooks_path = codex_dir / "hooks.json"
settings_path = codex_dir / "cdx-hook.json"
state_path = codex_dir / "cdx-hook-state.json"
wrapper_path = codex_dir / "hooks" / "cdx_hook_stop_handler.py"
config_path = codex_dir / "config.toml"

settings = None
settings_path_existed = settings_path.exists()
if settings_path.exists():
    try:
        settings = json.loads(settings_path.read_text(encoding="utf-8"))
    except Exception:
        settings = None

managed_hook_present = False
if hooks_path.exists():
    try:
        payload = json.loads(hooks_path.read_text(encoding="utf-8"))
    except Exception:
        payload = None
    if isinstance(payload, dict):
        hooks = payload.get("hooks")
        if isinstance(hooks, dict):
            stop_groups = hooks.get("Stop")
            if isinstance(stop_groups, list):
                filtered = []
                for group in stop_groups:
                    if isinstance(group, dict) and group.get("_managed_by") == "cdx-hook":
                        managed_hook_present = True
                        continue
                    filtered.append(group)
                if filtered:
                    hooks["Stop"] = filtered
                else:
                    hooks.pop("Stop", None)
                if managed_hook_present:
                    hooks_path.write_text(
                        json.dumps(payload, indent=2, sort_keys=True) + "\n",
                        encoding="utf-8",
                    )

for path in (settings_path, state_path, wrapper_path):
    try:
        if path.exists():
            path.unlink()
    except OSError:
        pass

try:
    if config_path.exists() and config_path.read_text(encoding="utf-8") == OWNED_CONFIG_TOML:
        owned_by_settings = bool(settings and settings.get("owned_config_toml"))
        if owned_by_settings or not settings_path_existed:
            config_path.unlink()
except OSError:
    pass
PY
}

hook_disable_project_managed_stop() {
  local project_root="${1:-$PWD}"
  local hook_cli=""

  if ! hook_project_has_managed_state "$project_root"; then
    return 0
  fi

  hook_cli="$(hook_resolve_cli)"
  if [[ -n "$hook_cli" && -x "$hook_cli" ]]; then
    if "$hook_cli" stop off --project "$project_root" >/dev/null 2>&1; then
      return 0
    fi
  fi

  hook_inline_disable_project_managed_stop "$project_root"
}

hook_cleanup_on_exit() {
  if (( ! hook_cleanup_after_run )); then
    return 0
  fi

  hook_cleanup_after_run=0
  if ! hook_disable_project_managed_stop "$hook_cleanup_project_root" >/dev/null 2>&1; then
    printf '%s\n' "codex_wp: failed to clean temporary stop hook for $hook_cleanup_project_root." >&2
  fi
}

hook_progress_bar() {
  local used="$1"
  local total="$2"
  local width=10
  local filled=0
  local empty=0
  local bar=""
  local i

  (( total > 0 )) || total=1
  filled=$(( used * width / total ))
  if (( filled > width )); then
    filled=$width
  fi
  empty=$(( width - filled ))

  for ((i = 0; i < filled; i++)); do
    bar+="█"
  done
  for ((i = 0; i < empty; i++)); do
    bar+="░"
  done

  printf '%s\n' "$bar"
}

hook_parse_session_id() {
  local source_file="$1"
  local python_bin
  python_bin="$(hook_python_bin)"

  "$python_bin" - "$source_file" <<'PY' 2>/dev/null
import json
import sys

path = sys.argv[1]
with open(path, encoding="utf-8") as handle:
    for line in handle:
        line = line.strip()
        if not line:
            continue
        try:
            payload = json.loads(line)
        except json.JSONDecodeError:
            continue
        if not isinstance(payload, dict):
            continue
        if payload.get("type") == "session_meta":
            body = payload.get("payload")
            if not isinstance(body, dict):
                continue
            value = body.get("id")
            if value:
                print(value)
                raise SystemExit(0)
        if payload.get("type") == "thread.started":
            value = payload.get("thread_id")
            if value:
                print(value)
                raise SystemExit(0)
raise SystemExit(1)
PY
}

hook_parse_last_message() {
  local source_file="$1"
  local python_bin
  python_bin="$(hook_python_bin)"

  "$python_bin" - "$source_file" <<'PY' 2>/dev/null
import json
import sys

def flatten_text(value):
    if isinstance(value, str):
        return value
    if isinstance(value, list):
        parts = []
        for item in value:
            if not isinstance(item, dict):
                continue
            if item.get("type") in {"output_text", "text"}:
                text = item.get("text")
                if isinstance(text, str) and text.strip():
                    parts.append(text.strip())
        return " ".join(parts)
    return ""

last = ""
with open(sys.argv[1], encoding="utf-8") as handle:
    for line in handle:
        line = line.strip()
        if not line:
            continue
        try:
            payload = json.loads(line)
        except json.JSONDecodeError:
            continue
        if not isinstance(payload, dict):
            continue

        if payload.get("type") == "event_msg":
            body = payload.get("payload")
            if not isinstance(body, dict):
                continue
            if body.get("role") == "assistant":
                text = flatten_text(body.get("content"))
                if text.strip():
                    last = text.strip()
        elif payload.get("type") == "item.completed":
            item = payload.get("item")
            if not isinstance(item, dict):
                continue
            if item.get("type") == "agent_message":
                text = flatten_text(item.get("text"))
                if text.strip():
                    last = text.strip()

last = last.strip()
if last:
    print(last)
PY
}

hook_extract_exec_prompt() {
  local -a argv=("$@")
  local prompt_index=""

  prompt_index="$(find_exec_prompt_index "${argv[@]}")"
  [[ "$prompt_index" =~ ^-?[0-9]+$ ]] || return 0
  if (( prompt_index < 0 || prompt_index >= ${#argv[@]} )); then
    return 0
  fi
  if [[ "${argv[$prompt_index]}" == "-" ]]; then
    return 0
  fi
  printf '%s' "${argv[$prompt_index]}"
}

hook_resolve_session_file() {
  local session_id="$1"
  local sessions_root="${HOME:-}/.codex/sessions"

  [[ -n "$session_id" ]] || return 1
  [[ -d "$sessions_root" ]] || return 1

  find "$sessions_root" -type f -name "*${session_id}*.jsonl" 2>/dev/null | LC_ALL=C sort | tail -n 1
}

hook_write_auto_prompt_schema() {
  local schema_path="$1"

  cat >"$schema_path" <<'EOF'
{
  "type": "object",
  "additionalProperties": false,
  "required": ["continue_session", "next_prompt", "operator_summary", "reasoning_note"],
  "properties": {
    "continue_session": { "type": "boolean" },
    "next_prompt": { "type": "string" },
    "operator_summary": { "type": "string" },
    "reasoning_note": { "type": "string" }
  }
}
EOF
}

hook_build_auto_prompt_request() {
  local session_file="$1"
  local initial_prompt="$2"
  local current_prompt="$3"
  local last_msg="$4"
  local turn="$5"
  local total="$6"
  local fallback_prompt="$7"
  local python_bin=""
  python_bin="$(hook_python_bin)"

  "$python_bin" - "$session_file" "$initial_prompt" "$current_prompt" "$last_msg" "$turn" "$total" "$fallback_prompt" <<'PY'
import json
import sys
from pathlib import Path

session_file, initial_prompt, current_prompt, last_msg, turn, total, fallback_prompt = sys.argv[1:]


def flatten_text(value):
    if isinstance(value, str):
        return " ".join(value.split())
    if isinstance(value, list):
        parts = []
        for item in value:
            if not isinstance(item, dict):
                continue
            text = item.get("text")
            if isinstance(text, str) and text.strip():
                parts.append(" ".join(text.split()))
        return " ".join(parts)
    return ""


recent_messages = []
session_path = Path(session_file) if session_file else None
if session_path and session_path.exists():
    for raw_line in session_path.read_text(encoding="utf-8", errors="replace").splitlines():
        raw_line = raw_line.strip()
        if not raw_line:
            continue
        try:
            payload = json.loads(raw_line)
        except json.JSONDecodeError:
            continue
        if not isinstance(payload, dict) or payload.get("type") != "event_msg":
            continue
        body = payload.get("payload")
        if not isinstance(body, dict):
            continue
        role = body.get("role")
        if role not in {"user", "assistant"}:
            continue
        text = flatten_text(body.get("content"))
        if text:
            recent_messages.append({"role": role, "text": text})

context = {
    "initial_goal": " ".join(initial_prompt.split()),
    "current_prompt": " ".join(current_prompt.split()),
    "latest_assistant_message": " ".join(last_msg.split()),
    "turn": int(turn),
    "budget_total": int(total),
    "remaining_after_this_turn": max(int(total) - int(turn), 0),
    "fallback_prompt": " ".join(fallback_prompt.split()),
    "recent_messages": recent_messages[-6:],
}

print(
    "\n".join(
        [
            "<task>",
            "Generate the next prompt for a Codex headless resume loop.",
            "Return JSON only. The response must match the provided schema exactly.",
            "",
            "Rules:",
            "- Continue the same task instead of restarting it.",
            "- Avoid meta chatter and supervision language.",
            "- If the task already looks complete, or no safe next step is obvious, set continue_session to false and next_prompt to an empty string.",
            "- If continue_session is true, next_prompt must be a short actionable user prompt for the next resume step.",
            "- operator_summary should be one concise operator-facing sentence.",
            "- reasoning_note should be one short internal note.",
            "",
            "Context JSON:",
            json.dumps(context, ensure_ascii=False, indent=2),
            "</task>",
        ]
    ).strip()
)
PY
}

hook_normalize_auto_prompt_result() {
  local raw_text="$1"
  local python_bin=""
  python_bin="$(hook_python_bin)"

  "$python_bin" - "$raw_text" <<'PY'
import json
import sys


def compact(value):
    if not isinstance(value, str):
        return ""
    return " ".join(value.split())


try:
    payload = json.loads(sys.argv[1])
except json.JSONDecodeError as exc:
    raise SystemExit(f"invalid_json:{exc}")

if not isinstance(payload, dict):
    raise SystemExit("not_object")

continue_session = payload.get("continue_session")
if not isinstance(continue_session, bool):
    raise SystemExit("invalid_continue_session")

next_prompt = compact(payload.get("next_prompt", ""))
operator_summary = compact(payload.get("operator_summary", ""))
reasoning_note = compact(payload.get("reasoning_note", ""))

if continue_session and not next_prompt:
    raise SystemExit("missing_next_prompt")

if not continue_session:
    next_prompt = ""

print(
    json.dumps(
        {
            "continue_session": continue_session,
            "next_prompt": next_prompt,
            "operator_summary": operator_summary,
            "reasoning_note": reasoning_note,
        },
        ensure_ascii=False,
    )
)
PY
}

hook_read_auto_prompt_decision() {
  local payload_json="$1"
  local continue_var_name="$2"
  local next_prompt_var_name="$3"
  local operator_summary_var_name="$4"
  local python_bin=""
  local -a fields=()
  python_bin="$(hook_python_bin)"

  mapfile -t fields < <("$python_bin" - "$payload_json" <<'PY'
import json
import sys

payload = json.loads(sys.argv[1])


def render(value):
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, str):
        return value
    return ""


print(render(payload.get("continue_session")))
print(render(payload.get("next_prompt")))
print(render(payload.get("operator_summary")))
PY
)

  printf -v "$continue_var_name" '%s' "${fields[0]:-}"
  printf -v "$next_prompt_var_name" '%s' "${fields[1]:-}"
  printf -v "$operator_summary_var_name" '%s' "${fields[2]:-}"
}

hook_generate_auto_prompt_result() {
  local session_id="$1"
  local initial_prompt="$2"
  local current_prompt="$3"
  local last_msg="$4"
  local turn="$5"
  local total="$6"
  local tmpdir="$7"
  local project_root="${hook_run_project_root:-$PWD}"
  local session_file=""
  local schema_path="$tmpdir/auto-prompt-schema.json"
  local output_path="$tmpdir/auto-prompt-turn-${turn}.json"
  local prompt_text=""
  local raw_output=""
  local normalized_output=""
  local -a command=()

  session_file="$(hook_resolve_session_file "$session_id" || true)"
  hook_write_auto_prompt_schema "$schema_path"
  prompt_text="$(hook_build_auto_prompt_request "$session_file" "$initial_prompt" "$current_prompt" "$last_msg" "$turn" "$total" "$hook_prompt")"
  command=(
    "$codex_bin"
    -c "$config_arg"
    exec
    --json
    --ephemeral
    --skip-git-repo-check
    -C "$project_root"
    -s read-only
    --dangerously-bypass-approvals-and-sandbox
    --output-schema "$schema_path"
    -o "$output_path"
    -
  )
  if command -v timeout >/dev/null 2>&1; then
    command=(timeout 120 "${command[@]}")
  fi

  if ! printf '%s' "$prompt_text" | "${command[@]}" >/dev/null 2>&1; then
    return 1
  fi
  [[ -f "$output_path" ]] || return 1

  raw_output="$(<"$output_path")"
  normalized_output="$(hook_normalize_auto_prompt_result "$raw_output" 2>/dev/null || true)"
  [[ -n "$normalized_output" ]] || return 1
  printf '%s' "$normalized_output"
}

hook_extract_intent_text() {
  local session_id="$1"
  local session_file=""
  local intent_text=""
  local -a command=()
  local processing_provider="pi"
  local preflight_timeout=0
  local runtime_timeout=0
  local timeout_seconds=0

  session_file="$(hook_resolve_session_file "$session_id")" || true
  [[ -n "$session_file" ]] || return 0

  preflight_timeout="$(positive_int_env_or_default CDX_HOOK_EXTRACT_INTENT_PREFLIGHT_TIMEOUT 30)"
  runtime_timeout="$(positive_int_env_or_default CDX_HOOK_EXTRACT_INTENT_RUNTIME_TIMEOUT 300)"
  timeout_seconds=$(( preflight_timeout + runtime_timeout + 5 ))

  command=(
    extract-intent_cli
    --input "$session_file"
    --pretty
    --processing-provider "$processing_provider"
    --preflight-timeout "$preflight_timeout"
    --runtime-timeout "$runtime_timeout"
  )

  if command -v timeout >/dev/null 2>&1; then
    command=(timeout "$timeout_seconds" "${command[@]}")
  fi

  intent_text="$("${command[@]}" 2>/dev/null || true)"

  if [[ -n "$intent_text" ]]; then
    printf '%s' "$intent_text"
  fi
}

hook_build_last_message_summary_prompt() {
  local last_msg="$1"
  local python_bin=""
  python_bin="$(hook_python_bin)"

  "$python_bin" - "$last_msg" <<'PY'
import sys

source_message = " ".join(sys.argv[1].split())[:1200]
print(
    "\n".join(
        [
            "<task>",
            "Marker: CDX_WP_LAST_MESSAGE_RU3_SUMMARY",
            "Compress the source assistant message into Russian bullets for a Mattermost stop notification.",
            "Preserve concrete meaning. Remove filler.",
            "",
            "Output contract:",
            "- exactly 3 lines",
            "- each line starts with '- '",
            "- each bullet body contains at most 3 words",
            "- Russian only",
            "- no intro or outro",
            "",
            "Source assistant message:",
            "<<<",
            source_message,
            ">>>",
            "</task>",
        ]
    ).strip()
)
PY
}

hook_normalize_ru3_summary() {
  local summary_text="$1"
  local python_bin=""
  python_bin="$(hook_python_bin)"

  "$python_bin" - "$summary_text" <<'PY'
import re
import sys

lines = [line.strip() for line in sys.argv[1].splitlines() if line.strip()]
if len(lines) != 3:
    raise SystemExit(1)

bullets = []
for line in lines:
    cleaned = re.sub(r"^\s*(?:[-*•]+|\d+[.)])\s*", "", line)
    cleaned = " ".join(cleaned.split())
    words = cleaned.split()
    if not words:
        raise SystemExit(1)
    bullets.append(f"- {' '.join(words[:3])}")

normalized = "\n".join(bullets)
if not re.search(r"[А-Яа-яЁё]", normalized):
    raise SystemExit(1)

print(normalized)
PY
}

hook_summarize_last_message_ru3() {
  local last_msg="$1"
  local prompt_text=""
  local summary_text=""
  local normalized_summary=""
  local tmpdir=""
  local output_path=""
  local project_root="${hook_run_project_root:-$PWD}"
  local -a command=()

  [[ -n "$last_msg" ]] || return 0

  prompt_text="$(hook_build_last_message_summary_prompt "$last_msg")"
  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/codex-wp-lastmsg-XXXXXX")" || return 0
  output_path="$tmpdir/summary.txt"
  command=(
    "$codex_bin"
    -c "$config_arg"
    exec
    --json
    --ephemeral
    --skip-git-repo-check
    -C "$project_root"
    -s read-only
    --dangerously-bypass-approvals-and-sandbox
    -o "$output_path"
    -
  )
  if command -v timeout >/dev/null 2>&1; then
    command=(timeout 90 "${command[@]}")
  fi

  if printf '%s' "$prompt_text" | "${command[@]}" >/dev/null 2>&1; then
    if [[ -f "$output_path" ]]; then
      summary_text="$(<"$output_path")"
    fi
    normalized_summary="$(hook_normalize_ru3_summary "$summary_text" 2>/dev/null || true)"
  fi

  rm -rf "$tmpdir"
  if [[ -n "$normalized_summary" ]]; then
    printf '%s' "$normalized_summary"
  fi
}

hook_format_last_message_block() {
  local transport="$1"
  local last_msg="${2:-}"
  local summary_text=""

  if [[ -z "$last_msg" ]]; then
    printf '%s' "💬 —"
    return 0
  fi

  if [[ "$transport" == "mattermost" && "$hook_last_message_format" == "ru3" ]]; then
    summary_text="$(hook_summarize_last_message_ru3 "$last_msg" || true)"
    if [[ -n "$summary_text" ]]; then
      printf '💬\n%s' "$summary_text"
      return 0
    fi
  fi

  printf '💬 %s' "$last_msg"
}

hook_send_notification() {
  local message="$1"
  local -a command=(t2me send)

  if [[ -n "$hook_target" ]]; then
    command+=(--target "$hook_target")
  fi
  command+=("$message")

  if ! "${command[@]}" >/dev/null 2>&1; then
    printf '%s\n' "codex_wp: hook-loop: t2me send failed." >&2
    return 1
  fi

  return 0
}

hook_resolve_mattermost_bin() {
  local candidate="${MATTERMOST_TO_ME_BIN:-/home/pets/TOOLS/mattermost_to_me_cli/mattermost_to_me}"
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi
  command -v mattermost_to_me || true
}

hook_send_mattermost() {
  local message="$1"
  local mm_bin=""
  local -a env_args=()

  mm_bin="$(hook_resolve_mattermost_bin)"
  if [[ -z "$mm_bin" ]]; then
    printf '%s\n' "codex_wp: hook-loop: mattermost_to_me not found. Set MATTERMOST_TO_ME_BIN or install mattermost_to_me_cli." >&2
    return 1
  fi

  if [[ -f "/home/pets/TOOLS/mattermost_to_me_cli/config/credentials.env" ]]; then
    env_args+=("MATTERMOST_TO_ME_ENV_PATH=/home/pets/TOOLS/mattermost_to_me_cli/config/credentials.env")
  fi
  if [[ -d "/home/pets/TOOLS/mattermost_to_me_cli/data" ]]; then
    env_args+=("MATTERMOST_TO_ME_CACHE_PATH=/home/pets/TOOLS/mattermost_to_me_cli/data/runtime.json")
  fi

  if ! env "${env_args[@]}" "$mm_bin" --only mattermost "$message" >/dev/null 2>&1; then
    printf '%s\n' "codex_wp: hook-loop: mattermost_to_me send failed." >&2
    return 1
  fi

  return 0
}

hook_send_mattermost_with_telegram_fallback() {
  local mattermost_message="$1"
  local telegram_message="$2"

  if hook_send_mattermost "$mattermost_message"; then
    return 0
  fi

  printf '%s\n' "codex_wp: hook-loop: falling back to t2me after mattermost failure." >&2
  hook_send_notification "$telegram_message"
}

hook_emit_manager_event() {
  local event="$1"
  local train_id="$2"
  local session_id="$3"
  local turn="$4"
  local total="$5"
  local last_msg="${6:-}"
  local intent_text="${7:-}"
  local failure_text="${8:-}"
  local next_prompt="${9:-}"
  local next_prompt_source="${10:-}"
  local stop_reason="${11:-}"
  local python_bin=""
  local project_name=""
  local supervision=""

  python_bin="$(hook_python_bin)"
  project_name="$(basename "${hook_run_project_root:-$PWD}")"
  supervision="$(hook_effective_supervision)"

  "$python_bin" - "$event" "$train_id" "$session_id" "$turn" "$total" "$project_name" "$last_msg" "$intent_text" "$failure_text" "$supervision" "$next_prompt" "$next_prompt_source" "$stop_reason" <<'PY'
import json
import sys

event, train_id, session_id, turn, total, project_name, last_msg, intent_text, failure_text, supervision, next_prompt, next_prompt_source, stop_reason = sys.argv[1:]

payload = {
    "type": "hook.delivery",
    "delivery": "manager",
    "hook_event_name": "Stop",
    "event": event,
    "supervision": supervision,
    "train_id": train_id,
    "session_id": session_id,
    "turn": int(turn),
    "total": int(total),
    "project": project_name,
    "last_assistant_message": last_msg,
}
if intent_text:
    payload["intent_text"] = intent_text
if failure_text:
    payload["failure_text"] = failure_text
if next_prompt:
    payload["next_prompt"] = next_prompt
if next_prompt_source:
    payload["next_prompt_source"] = next_prompt_source
if stop_reason:
    payload["stop_reason"] = stop_reason

print(json.dumps(payload, ensure_ascii=False))
PY
}

hook_dispatch_delivery() {
  local event="$1"
  local train_id="$2"
  local session_id="$3"
  local turn="$4"
  local total="$5"
  local last_msg="${6:-}"
  local intent_text="${7:-}"
  local failure_text="${8:-}"
  local next_prompt="${9:-}"
  local next_prompt_source="${10:-}"
  local stop_reason="${11:-}"
  local telegram_text=""
  local mattermost_text=""

  if [[ "$hook_delivery" == "manager" ]]; then
    hook_emit_manager_event "$event" "$train_id" "$session_id" "$turn" "$total" "$last_msg" "$intent_text" "$failure_text" "$next_prompt" "$next_prompt_source" "$stop_reason"
    return 0
  fi

  if [[ "$event" == "error" ]]; then
    telegram_text="$(hook_build_error_notification "$train_id" "$session_id" "$turn" "$total" "$failure_text" "$last_msg" "telegram")"
    mattermost_text="$(hook_build_error_notification "$train_id" "$session_id" "$turn" "$total" "$failure_text" "$last_msg" "mattermost")"
  else
    telegram_text="$(hook_build_notification "$event" "$train_id" "$session_id" "$turn" "$total" "$last_msg" "$intent_text" "telegram" "$next_prompt" "$next_prompt_source" "$stop_reason")"
    mattermost_text="$(hook_build_notification "$event" "$train_id" "$session_id" "$turn" "$total" "$last_msg" "$intent_text" "mattermost" "$next_prompt" "$next_prompt_source" "$stop_reason")"
  fi

  case "$hook_delivery" in
    telegram)
      hook_send_notification "$telegram_text" || true
      ;;
    mattermost)
      hook_send_mattermost_with_telegram_fallback "$mattermost_text" "$telegram_text" || true
      ;;
    both)
      hook_send_notification "$telegram_text" || true
      hook_send_mattermost "$mattermost_text" || true
      ;;
  esac
}

hook_generate_train_id() {
  local python_bin=""
  local timestamp=""
  local suffix=""

  python_bin="$(hook_python_bin)"
  timestamp="$(date -u +%Y%m%d-%H%M%S)"
  suffix="$("$python_bin" - <<'PY'
import uuid
print(uuid.uuid4().hex[:4].upper())
PY
)"

  printf 'TRAIN-%s-%s\n' "$timestamp" "$suffix"
}

hook_preview_text() {
  local raw_text="${1:-}"
  local normalized="${raw_text//$'\n'/ }"
  normalized="${normalized//$'\r'/ }"
  normalized="${normalized//$'\t'/ }"
  normalized="${normalized#"${normalized%%[![:space:]]*}"}"
  normalized="${normalized%"${normalized##*[![:space:]]}"}"
  printf '%s' "${normalized:0:120}"
}

hook_build_notification() {
  local event="$1"
  local train_id="$2"
  local session_id="$3"
  local turn="$4"
  local total="$5"
  local last_msg="$6"
  local intent_text="${7:-}"
  local transport="${8:-telegram}"
  local next_prompt="${9:-}"
  local next_prompt_source="${10:-}"
  local stop_reason="${11:-}"
  local header=""
  local footer=""
  local bar=""
  local project_name=""
  local message=""
  local msg_block=""
  local next_prompt_preview=""

  if [[ "$event" == "stop" ]]; then
    header="🟡 Codex Exec Paused -> Continuing"
    if [[ "$transport" == "mattermost" ]]; then
      if [[ -n "$next_prompt_source" ]]; then
        footer="$(printf '▶ next prompt (%s):\n%s' "$next_prompt_source" "$next_prompt")"
      else
        footer="$(printf '▶ next prompt:\n%s' "$next_prompt")"
      fi
    else
      next_prompt_preview="$(hook_preview_text "$next_prompt")"
      if [[ -n "$next_prompt_source" ]]; then
        footer="▶ next prompt (${next_prompt_source}): ${next_prompt_preview}"
      else
        footer="▶ next prompt: ${next_prompt_preview}"
      fi
    fi
  else
    header="🏁 Codex Exec Finished"
    if [[ -n "$stop_reason" ]]; then
      footer="✅ finished: $stop_reason"
    else
      footer="✅ completed all ${total} steps"
    fi
  fi

  bar="$(hook_progress_bar "$turn" "$total")"
  project_name="$(basename "${hook_run_project_root:-$PWD}")"
  msg_block="$(hook_format_last_message_block "$transport" "$last_msg")"

  message="$(printf '%s\n\n📁 Project: %s\n🪪 Run ID: %s\n🔁 Step: %s/%s\n🆔 Session: %s\n\n📊 Progress: %s/%s  %s\n\n%s' \
    "$header" \
    "$project_name" \
    "$train_id" \
    "$turn" \
    "$total" \
    "$session_id" \
    "$turn" \
    "$total" \
    "$bar" \
    "$msg_block")"

  if [[ -n "$intent_text" ]]; then
    message+=$'\n\n'"$intent_text"
  fi

  message+=$'\n\n'"$footer"
  printf '%s' "$message"
}

hook_build_error_notification() {
  local train_id="$1"
  local session_id="$2"
  local turn="$3"
  local total="$4"
  local failure_text="$5"
  local last_msg="$6"
  local transport="${7:-telegram}"
  local bar=""
  local project_name=""
  local message=""
  local msg_block=""

  bar="$(hook_progress_bar "$turn" "$total")"
  project_name="$(basename "${hook_run_project_root:-$PWD}")"
  msg_block="$(hook_format_last_message_block "$transport" "$last_msg")"

  message="$(printf '🔴 Codex Exec Failed\n\n📁 Project: %s\n🪪 Run ID: %s\n🔁 Step: %s/%s\n🆔 Session: %s\n\n📊 Progress: %s/%s  %s\n\n%s\n%s\n\n🛑 stopped at step %s of %s' \
    "$project_name" \
    "$train_id" \
    "$turn" \
    "$total" \
    "$session_id" \
    "$turn" \
    "$total" \
    "$bar" \
    "$failure_text" \
    "$msg_block" \
    "$turn" \
    "$total")"
  printf '%s' "$message"
}

hook_run_codex_stream() {
  local output_file="$1"
  shift

  env -u OPENAI_BASE_URL -u OPENAI_API_BASE \
    "$codex_bin" -c "$config_arg" --dangerously-bypass-approvals-and-sandbox "$@" 2>&1 | tee "$output_file"
}

run_headless_hook_loop() {
  local -a initial_args=("$@")
  local -a resume_args=()
  local skip_git_repo_check=0
  local tmpdir=""
  local output_file=""
  local session_id=""
  local parsed_session_id=""
  local train_id=""
  local last_msg=""
  local intent_text=""
  local failure_text=""
  local initial_prompt=""
  local current_prompt=""
  local resolved_next_prompt=""
  local next_prompt_source=""
  local auto_prompt_json=""
  local auto_continue=""
  local auto_next_prompt=""
  local auto_operator_summary=""
  local stop_reason=""
  local exit_code=0
  local turn=0

  hook_require_headless_preconditions "${initial_args[@]}"
  initial_prompt="$(hook_extract_exec_prompt "${initial_args[@]}")"
  current_prompt="$initial_prompt"

  if array_has --skip-git-repo-check "${initial_args[@]}"; then
    skip_git_repo_check=1
  fi

  tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/codex-wp-hook-XXXXXX")" || \
    die "codex_wp: failed to create a temporary hook directory." 1
  train_id="$(hook_generate_train_id)"

  for ((turn = 1; turn <= hook_times; turn++)); do
    output_file="$tmpdir/iter-${turn}.jsonl"
    exit_code=0

    if (( turn == 1 )); then
      if ! hook_run_codex_stream "$output_file" "${initial_args[@]}"; then
        exit_code=${PIPESTATUS[0]}
      fi
    else
      resume_args=(exec resume --json)
      if (( skip_git_repo_check )); then
        resume_args+=(--skip-git-repo-check)
      fi
      resume_args+=("$session_id" "$current_prompt")
      if ! hook_run_codex_stream "$output_file" "${resume_args[@]}"; then
        exit_code=${PIPESTATUS[0]}
      fi
    fi

    parsed_session_id="$(hook_parse_session_id "$output_file" || true)"
    if [[ -n "$parsed_session_id" ]]; then
      if [[ -z "$session_id" ]]; then
        session_id="$parsed_session_id"
      elif [[ "$parsed_session_id" != "$session_id" ]]; then
        last_msg="$(hook_parse_last_message "$output_file" || true)"
        failure_text="❌ session_id changed unexpectedly (${parsed_session_id} != ${session_id})"
        hook_dispatch_delivery "error" "$train_id" "$session_id" "$turn" "$hook_times" "$last_msg" "" "$failure_text" || true
        rm -rf "$tmpdir"
        return 1
      fi
    fi

    last_msg="$(hook_parse_last_message "$output_file" || true)"

    if [[ -z "$session_id" ]]; then
      failure_text="❌ failed to parse session_id from codex JSON output"
      hook_dispatch_delivery "error" "$train_id" "-" "$turn" "$hook_times" "$last_msg" "" "$failure_text" || true
      rm -rf "$tmpdir"
      return 1
    fi

    if (( exit_code != 0 )); then
      failure_text="❌ codex exec failed (exit ${exit_code})"
      hook_dispatch_delivery "error" "$train_id" "$session_id" "$turn" "$hook_times" "$last_msg" "" "$failure_text" || true
      rm -rf "$tmpdir"
      return "$exit_code"
    fi

    intent_text=""
    if (( hook_extract_intent )); then
      intent_text="$(hook_extract_intent_text "$session_id" || true)"
    fi

    resolved_next_prompt=""
    next_prompt_source=""
    stop_reason=""
    if (( turn < hook_times )); then
      case "$hook_prompt_mode" in
        static)
          resolved_next_prompt="$hook_prompt"
          next_prompt_source="static"
          ;;
        auto|hybrid)
          auto_prompt_json="$(hook_generate_auto_prompt_result "$session_id" "$initial_prompt" "$current_prompt" "$last_msg" "$turn" "$hook_times" "$tmpdir" || true)"
          if [[ -z "$auto_prompt_json" ]]; then
            if [[ "$hook_prompt_mode" != "hybrid" ]]; then
              failure_text="❌ failed to generate the next prompt in auto mode"
              hook_dispatch_delivery "error" "$train_id" "$session_id" "$turn" "$hook_times" "$last_msg" "" "$failure_text" || true
              rm -rf "$tmpdir"
              return 1
            fi
            resolved_next_prompt="$hook_prompt"
            next_prompt_source="fallback"
          else
            hook_read_auto_prompt_decision "$auto_prompt_json" auto_continue auto_next_prompt auto_operator_summary
            if [[ "$auto_continue" == "true" ]]; then
              resolved_next_prompt="$auto_next_prompt"
              next_prompt_source="auto"
            elif (( hook_auto_stop_on_complete )); then
              stop_reason="${auto_operator_summary:-auto prompt marked the task complete}"
              hook_dispatch_delivery "complete" "$train_id" "$session_id" "$turn" "$hook_times" "$last_msg" "$intent_text" "" "" "" "$stop_reason" || true
              rm -rf "$tmpdir"
              return 0
            elif [[ "$hook_prompt_mode" == "hybrid" ]]; then
              resolved_next_prompt="$hook_prompt"
              next_prompt_source="fallback"
            else
              failure_text="❌ auto prompt marked the task complete, but --hook-auto-stop-on-complete is disabled"
              hook_dispatch_delivery "error" "$train_id" "$session_id" "$turn" "$hook_times" "$last_msg" "" "$failure_text" || true
              rm -rf "$tmpdir"
              return 1
            fi
          fi
          ;;
      esac
    fi

    if (( turn == hook_times )); then
      stop_reason="hook budget exhausted"
      hook_dispatch_delivery "complete" "$train_id" "$session_id" "$turn" "$hook_times" "$last_msg" "$intent_text" "" "" "" "$stop_reason" || true
    else
      hook_dispatch_delivery "stop" "$train_id" "$session_id" "$turn" "$hook_times" "$last_msg" "$intent_text" "" "$resolved_next_prompt" "$next_prompt_source" "" || true
      current_prompt="$resolved_next_prompt"
    fi
  done

  rm -rf "$tmpdir"
  return 0
}

if ! cdx_bin="$(resolve_cdx_bin)"; then
  if [[ -n "${CDX_BIN:-}" ]]; then
    die "codex_wp: CDX_BIN is set but not executable: ${CDX_BIN}" 127
  fi
  die "codex_wp: cdx not found. Install it or set CDX_BIN." 127
fi

if ! codex_bin="$(resolve_codex_bin)"; then
  if [[ -n "${CODEX_BIN:-}" ]]; then
    die "codex_wp: CODEX_BIN is set but not executable: ${CODEX_BIN}" 127
  fi
  die "codex_wp: codex not found. Install it or set CODEX_BIN." 127
fi

proxy_setup="$("$cdx_bin" proxy --print-env-only)"
eval "$proxy_setup"

base_url="${CLIPROXY_BASE_URL:-}"
[[ -n "$base_url" ]] || die "codex_wp: missing CLIPROXY_BASE_URL from proxy setup."

config_arg="openai_base_url=\"$base_url\""
trap 'hook_cleanup_on_exit' EXIT
hook_run_project_root="$(hook_resolve_project_root_from_args "$@")"

# ── Hook activation ──────────────────────────────────────────────────────────
if [[ -n "$hook_mode" ]]; then
  if hook_is_headless_mode "$@"; then
    run_headless_hook_loop "$@"
    exit $?
  fi

  if [[ "$hook_prompt_mode" != "static" ]]; then
    die "codex_wp: --hook-prompt-mode auto/hybrid is only supported for headless 'exec --json' hook runs." 2
  fi
  if (( hook_auto_stop_on_complete )); then
    die "codex_wp: --hook-auto-stop-on-complete is only supported for headless 'exec --json' hook runs." 2
  fi

  if (( hook_supervision_explicit )); then
    die "codex_wp: --hook-supervision is only supported for headless 'exec --json' hook runs." 2
  fi
  if [[ "$hook_delivery" == "manager" ]]; then
    die "codex_wp: --hook-delivery $hook_delivery is only supported for headless 'exec --json' hook runs." 2
  fi

  hook_cli="$(hook_resolve_cli)"
  [[ -n "$hook_cli" && -x "$hook_cli" ]] || \
    die "codex_wp: cdx-hook not found. Install cdx_hooks_cli." 127

  hook_disable_project_managed_stop "$hook_run_project_root" || \
    die "codex_wp: failed to reset existing managed stop hook for $hook_run_project_root." 2

  hook_args=(stop on --project "$hook_run_project_root" --mode resume --ask "$hook_prompt" --times "$hook_times")
  hook_args+=(--delivery "$hook_delivery")
  if (( hook_last_message_format_explicit )) || [[ "$hook_last_message_format" != "raw" ]]; then
    hook_args+=(--last-message-format "$hook_last_message_format")
  fi
  if [[ -n "$hook_target" ]]; then
    hook_args+=(--target "$hook_target")
  fi
  if (( hook_extract_intent )); then
    hook_args+=(--extract-intent)
  fi

  printf 'codex_wp: activating hook → %s %s\n' "$hook_cli" "${hook_args[*]}"
  "$hook_cli" "${hook_args[@]}" || die "codex_wp: cdx-hook activation failed." 2
  hook_cleanup_after_run=1
  hook_cleanup_project_root="$hook_run_project_root"
elif (( ! help_requested )) && hook_is_interactive_mode "$@"; then
  hook_disable_project_managed_stop "$hook_run_project_root" || \
    die "codex_wp: failed to clear managed stop hook for $hook_run_project_root." 2
fi

# Preserve legacy bypass mode only when the caller did not choose an execution policy.
# --no-alt-screen keeps scrollback working inside Zellij regardless of that policy.
codex_flags=()
if ! has_explicit_execution_policy "$@"; then
  codex_flags=(--dangerously-bypass-approvals-and-sandbox)
fi
if [[ -n "${ZELLIJ:-}" ]]; then
  codex_flags+=(--no-alt-screen)
fi

if (( hook_cleanup_after_run )); then
  cleanup_status=0
  if env -u OPENAI_BASE_URL -u OPENAI_API_BASE \
    "$codex_bin" -c "$config_arg" "${codex_flags[@]}" "$@"; then
    codex_status=0
  else
    codex_status=$?
  fi
  if ! hook_disable_project_managed_stop "$hook_cleanup_project_root"; then
    cleanup_status=$?
    printf '%s\n' "codex_wp: failed to clean temporary stop hook for $hook_cleanup_project_root." >&2
  fi
  hook_cleanup_after_run=0
  if (( cleanup_status != 0 && codex_status == 0 )); then
    exit "$cleanup_status"
  fi
  exit "$codex_status"
fi

exec env -u OPENAI_BASE_URL -u OPENAI_API_BASE \
  "$codex_bin" -c "$config_arg" "${codex_flags[@]}" "$@"
