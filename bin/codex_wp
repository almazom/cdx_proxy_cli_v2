#!/usr/bin/env bash
set -euo pipefail

script_path="$(readlink -f "$0")"
script_dir="$(cd "$(dirname "$script_path")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

cdx_bin="${CDX_BIN:-$repo_root/.venv/bin/cdx}"
if [[ ! -x "$cdx_bin" ]]; then
  cdx_bin="$(command -v cdx || true)"
fi
if [[ -z "$cdx_bin" || ! -x "$cdx_bin" ]]; then
  echo "codex_wp: cdx not found. Install it or set CDX_BIN." >&2
  exit 127
fi

codex_bin="${CODEX_BIN:-$(command -v codex || true)}"
if [[ -z "$codex_bin" || ! -x "$codex_bin" ]]; then
  echo "codex_wp: codex not found. Install it or set CODEX_BIN." >&2
  exit 127
fi

eval "$("$cdx_bin" proxy --print-env-only)"
exec "$codex_bin" --dangerously-bypass-approvals-and-sandbox "$@"
